---
import styles from '../styles/Header.module.css';
import { t } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import MobileDock from './MobileDock.astro';
import type { Language } from '../i18n/utils';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

interface Props {
	lang: Language;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
const craftedMenuId = `crafted-menu-${lang}`;
const craftedMenuButtonId = `crafted-menu-button-${lang}`;
---

<header class={styles.siteHeader}>
	<div class={styles.headerContainer}>
		<a href={`/${lang}`} class={styles.logo}>
			<Image src="/logo-updated-150x150.webp" alt="ElPuas logo" width="150" height="150" loading="eager" decoding="async" />
		</a>
		<nav class={styles.mainNav}>
			<ul>
				<li><a href={`/${lang}/about`}>{t('nav.about', lang)}</a></li>
				<li><a href={`/${lang}/services`}>{t('nav.services', lang)}</a></li>
				<li class={styles.navDropdown}>
					<div class={styles.navDropdownTrigger}>
						<a href={`/${lang}/crafted-with-love/`}>{t('nav.crafted', lang)}</a>
						<button
							id={craftedMenuButtonId}
							class={styles.navDropdownButton}
							type="button"
							aria-haspopup="true"
							aria-expanded="false"
							aria-controls={craftedMenuId}
							data-nav-dropdown-button
						>
							<span class="sr-only">Toggle {t('nav.crafted', lang)} menu</span>
							<Icon name="ph:caret-down" width="16" height="16" aria-hidden="true" />
						</button>
					</div>
					<ul
						id={craftedMenuId}
						class={styles.navDropdownMenu}
						role="menu"
						aria-labelledby={craftedMenuButtonId}
						hidden
						data-nav-dropdown-menu
					>
						<li role="none">
							<a href={`/${lang}/epdc-labs`} role="menuitem">{t('nav.labs', lang)}</a>
						</li>
					</ul>
				</li>
				<li><a href={`/${lang}/blog`}>{t('nav.blog', lang)}</a></li>
				<li><a href={`/${lang}/contact`}>{t('nav.contact', lang)}</a></li>
			</ul>
		</nav>
		<div class={styles.headerControls}>
			<LanguageSwitcher currentLang={lang} />
			<button 
				id="bw-toggle" 
				class={styles.bwToggle}
				aria-label="Toggle black and white mode"
				type="button"
			>
				<Icon name="ph:eye-slash" width="20" height="20" aria-hidden="true" />
			</button>
		</div>
	</div>
</header>

<MobileDock lang={lang} currentPath={currentPath} />

<script>
	const dropdownButtons = document.querySelectorAll('[data-nav-dropdown-button]');

	const closeDropdown = (button: Element) => {
		const menuId = button.getAttribute('aria-controls');
		const menu = menuId ? document.getElementById(menuId) : null;

		button.setAttribute('aria-expanded', 'false');
		menu?.setAttribute('hidden', '');
	};

	const openDropdown = (button: Element) => {
		const menuId = button.getAttribute('aria-controls');
		const menu = menuId ? document.getElementById(menuId) : null;

		button.setAttribute('aria-expanded', 'true');
		menu?.removeAttribute('hidden');
	};

	dropdownButtons.forEach((button) => {
		button.addEventListener('click', (event) => {
			event.preventDefault();
			event.stopPropagation();
			const isExpanded = button.getAttribute('aria-expanded') === 'true';

			dropdownButtons.forEach((otherButton) => {
				if (otherButton !== button) closeDropdown(otherButton);
			});

			if (isExpanded) {
				closeDropdown(button);
			} else {
				openDropdown(button);
			}
		});
	});

	document.addEventListener('click', (event) => {
		dropdownButtons.forEach((button) => {
			const menuId = button.getAttribute('aria-controls');
			const menu = menuId ? document.getElementById(menuId) : null;
			const target = event.target;

			if (
				target instanceof Node &&
				!button.contains(target) &&
				!(menu?.contains(target))
			) {
				closeDropdown(button);
			}
		});
	});

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') {
			dropdownButtons.forEach((button) => closeDropdown(button));
		}
	});
</script>
