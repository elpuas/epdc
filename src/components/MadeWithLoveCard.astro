---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import type { Language } from '../i18n/utils';

interface Props {
  project: CollectionEntry<'portfolio'>;
  lang: Language;
  index?: number;
}

const { project, lang, index = 0 } = Astro.props;
const { title, description } = project.data;
const projectUrl = `/${lang}/crafted-with-love/${project.slug}`;
const animationDelay = `${Math.min(index * 70, 560)}ms`;

function getProjectIcon(entry: CollectionEntry<'portfolio'>) {
  const haystack = `${entry.slug} ${entry.data.title} ${(entry.data.tags ?? []).join(' ')}`.toLowerCase();

  if (haystack.includes('ecommerce') || haystack.includes('woocommerce')) {
    return 'ph:shopping-bag-open';
  }

  if (haystack.includes('real estate') || haystack.includes('brokers') || haystack.includes('property')) {
    return 'ph:buildings';
  }

  if (haystack.includes('auto') || haystack.includes('car')) {
    return 'ph:car-profile';
  }

  if (haystack.includes('medical') || haystack.includes('fisio') || haystack.includes('health')) {
    return 'ph:first-aid-kit';
  }

  if (haystack.includes('travel') || haystack.includes('adventurers') || haystack.includes('tour')) {
    return 'ph:airplane-tilt';
  }

  if (haystack.includes('music') || haystack.includes('phonogram') || haystack.includes('fonogram')) {
    return 'ph:waveform';
  }

  if (haystack.includes('law') || haystack.includes('studio') || haystack.includes('ambrosio')) {
    return 'ph:scales';
  }

  return 'ph:globe-hemisphere-west';
}

const iconName = getProjectIcon(project);
---

<article class="made-with-love-card" style={`--entry-delay: ${animationDelay};`}>
  <a href={projectUrl} class="card-shell" aria-label={title}>
    <span class="media" aria-hidden="true">
      <Icon name={iconName} width="20" height="20" />
    </span>

    <div class="copy">
      <h2 class="card-title">{title}</h2>
      <p class="card-excerpt">{description}</p>
    </div>
  </a>
</article>

<style>
  .made-with-love-card {
    display: flex;
    min-width: 0;
    box-sizing: border-box;
  }

  .card-shell {
    flex: 1 1 auto;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-md);
    align-items: start;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    padding: var(--space-md);
    border: 1px solid var(--color-quaternary);
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-primary) 94%, var(--color-secondary) 6%);
    color: inherit;
    text-decoration: none;
    opacity: 0;
    animation: made-with-love-card-fade-in 560ms ease forwards;
    animation-delay: var(--entry-delay, 0ms);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .card-shell:hover,
  .card-shell:focus-within,
  .card-shell:focus-visible {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--color-secondary) 40%, var(--color-quaternary) 60%);
    background: color-mix(in srgb, var(--color-primary) 92%, var(--color-secondary) 8%);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-tertiary) 15%, transparent);
  }

  .copy {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .card-shell .card-title {
    margin: 0 0 0.35rem;
    font-size: clamp(1.1rem, 1rem + 0.3vw, 1.25rem);
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    background: linear-gradient(
      90deg,
      var(--color-secondary) 0%,
      var(--color-tertiary) 100%
    );
    color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
  }

  .card-shell .card-excerpt {
    margin: 0;
    font-size: 0.98rem;
    font-family: 'Montserrat VF', sans-serif;
    font-weight: 300;
    line-height: 1.55;
    color: var(--color-secondary);
  }

  .media {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--color-quaternary);
    border-radius: 8px;
    color: var(--color-tertiary);
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .media :global(svg) {
    display: block;
  }

  .card-shell:hover .media,
  .card-shell:focus-visible .media {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--color-secondary) 40%, var(--color-tertiary) 60%);
  }

  .card-shell:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-secondary) 65%, white 35%);
    outline-offset: 3px;
  }

  @keyframes made-with-love-card-fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card-shell,
    .media {
      transition: none;
    }

    .card-shell {
      opacity: 1;
      animation: none;
    }
  }
</style>
