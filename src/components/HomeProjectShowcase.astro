---
import { Icon } from 'astro-icon/components';

interface FeatureTag {
  icon: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  tags: FeatureTag[];
  tagsLabel?: string;
  href: string;
  linkLabel: string;
}

const { title, description, tags, tagsLabel = 'Project features', href, linkLabel } = Astro.props as Props;
---

<a
  class="home-project-showcase"
  href={href}
  aria-labelledby="home-project-showcase-title"
  data-enter-state="pending"
>
  <div class="showcase-copy">
    <h2 id="home-project-showcase-title" class="text-gradient-brand">{title}</h2>
    <p class="description">{description}</p>
    <span class="card-link project-link-affordance" aria-hidden="true">
      {linkLabel} <span class="project-link-arrow">&rarr;</span>
    </span>

    <ul class="tag-list" aria-label={tagsLabel}>
      {
        tags.map((tag, index) => (
          <li class="tag-item" style={`--tag-enter-delay: ${0.08 + index * 0.1}s;`} data-tag-item>
            <span class="tag-icon-shell" aria-hidden="true">
              <Icon name={tag.icon} width="18" height="18" class="tag-icon" />
            </span>
            <span class="tag-label">{tag.label}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="showcase-visual">
    <div class="visual-glow" aria-hidden="true"></div>
    <slot name="visual" />
  </div>
</a>

<style>
  .home-project-showcase {
    position: relative;
    display: grid;
    gap: clamp(var(--space-xl), 4vw, var(--space-3xl));
    align-items: center;
    padding: clamp(1.35rem, 2vw, 1.9rem) 0;
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      opacity 0.25s ease;
    isolation: isolate;

    @container (width > 900px) {
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);
    }
  }

  .home-project-showcase:hover,
  .home-project-showcase:focus-visible {
    transform: translateY(-2px);
    opacity: 0.98;
  }

  .home-project-showcase:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-tertiary) 50%, transparent);
    outline-offset: 3px;
  }

  .showcase-copy {
    display: grid;
    gap: clamp(1rem, 1.8vw, 1.5rem);
    align-content: center;
    min-width: 0;
    z-index: 1;
  }

  .showcase-copy h2 {
    position: relative;
    display: inline-block;
    margin: 0;
    max-width: 10ch;
    font-size: clamp(4rem, 3rem + 4.2vw, 6rem);
    line-height: 0.9;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  .description {
    margin: 0;
    color: var(--color-tertiary);
    font-size: var(--fontsize-editorial);
    line-height: var(--lineheight-editorial);
  }

  .project-link-affordance {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    width: fit-content;
    text-transform: capitalize;
  }

  .project-link-arrow {
    transition: transform 0.25s ease;
  }

  .home-project-showcase:hover .project-link-arrow,
  .home-project-showcase:focus-visible .project-link-arrow {
    transform: translateX(2px);
  }

  .tag-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin: clamp(0.35rem, 1vw, 0.6rem) 0 0;
    padding: 0;
    list-style: none;
  }

  .tag-item {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.8rem;
    min-width: 0;
    padding: 0.95rem 1rem;
    border: 1px solid var(--color-quaternary);
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-primary) 94%, var(--color-secondary) 6%);
    transition:
      opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.25s ease,
      background-color 0.25s ease,
      box-shadow 0.25s ease;
    transition-delay: var(--tag-enter-delay, 0s);
  }

  .home-project-showcase[data-enter-state='pending'] .tag-item {
    opacity: 0;
    transform: translate3d(0, 24px, 0);
  }

  .home-project-showcase[data-enter-state='visible'] .tag-item {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .tag-icon-shell {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--color-quaternary);
    border-radius: 8px;
    color: var(--color-tertiary);
    flex-shrink: 0;
  }

  .tag-icon {
    transition:
      transform 0.25s ease,
      color 0.25s ease;
  }

  .tag-label {
    min-width: 0;
    color: var(--color-secondary);
    font-size: clamp(0.96rem, 0.92rem + 0.16vw, 1.08rem);
    line-height: 1.2;
  }

  .home-project-showcase:hover .tag-item,
  .home-project-showcase:focus-visible .tag-item {
    border-color: color-mix(in srgb, var(--color-tertiary) 38%, var(--color-quaternary));
    background: color-mix(in srgb, var(--color-primary) 92%, var(--color-secondary) 8%);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-tertiary) 12%, transparent);
  }

  .home-project-showcase:hover .tag-icon-shell,
  .home-project-showcase:focus-visible .tag-icon-shell {
    border-color: color-mix(in srgb, var(--color-tertiary) 42%, var(--color-quaternary));
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-tertiary) 12%, transparent);
  }

  .home-project-showcase:hover .tag-icon,
  .home-project-showcase:focus-visible .tag-icon {
    transform: scale(1.06);
    color: var(--color-secondary);
  }

  .showcase-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-width: 0;
    padding: 0.4rem 0;
    order: -1;
    opacity: 0;
    transform: translate3d(0, 32px, 0);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.12s;
  }

  .home-project-showcase[data-enter-state='visible'] .showcase-visual {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .visual-glow {
    position: absolute;
    inset: 10% 8% 12% 12%;
    background:
      radial-gradient(circle at 42% 18%, rgba(216, 255, 0, 0.12), transparent 42%),
      radial-gradient(circle at 70% 78%, rgba(0, 255, 243, 0.09), transparent 38%);
    filter: blur(30px);
    opacity: 0.9;
    transform: rotate(-6deg);
    pointer-events: none;
  }

  @container (width > 900px) {
    .showcase-visual {
      justify-content: flex-end;
      order: 0;
      padding-left: clamp(1rem, 3vw, 2.5rem);
      padding-right: clamp(0rem, 1.4vw, 0.9rem);
      transform: translate3d(48px, 0, 0);
    }

    .home-project-showcase[data-enter-state='visible'] .showcase-visual {
      transform: translate3d(0, 0, 0);
    }
  }

  @media (max-width: 44rem) {
    .home-project-showcase {
      padding: 1.15rem 0;
    }

    .showcase-copy h2 {
      max-width: none;
    }

    .showcase-copy h2::after {
      right: -0.48rem;
      bottom: 0.56rem;
    }

    .tag-list {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-project-showcase,
    .visual-glow,
    .tag-item,
    .showcase-visual {
      transition: none;
      transform: none;
    }

    .showcase-visual {
      opacity: 1;
    }
  }
</style>

<script>
  if (typeof window !== 'undefined') {
    const showcases = [...document.querySelectorAll('.home-project-showcase:not([data-enter-bound])')];

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
      showcases.forEach((showcase) => {
        showcase.setAttribute('data-enter-state', 'visible');
        showcase.setAttribute('data-enter-bound', 'true');
      });
    } else if (!window.__epdcProjectShowcaseObserver) {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            entry.target.setAttribute('data-enter-state', 'visible');
            observer.unobserve(entry.target);
          }
        },
        {
          threshold: 0.18,
          rootMargin: '0px 0px -10% 0px',
        }
      );

      const observeShowcases = (targets) => {
        targets.forEach((showcase) => {
          showcase.setAttribute('data-enter-bound', 'true');
          observer.observe(showcase);
        });
      };

      window.__epdcProjectShowcaseObserver = { observer, observeShowcases };
      observeShowcases(showcases);
    } else {
      window.__epdcProjectShowcaseObserver.observeShowcases(showcases);
    }
  }
</script>
