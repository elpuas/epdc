---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';

interface SocialLink {
	href: string;
	icon: string;
	label: string;
}

interface Props {
	image?: ImageMetadata;
	alt?: string;
	name?: string;
	role?: string;
	bio?: string;
	expertise?: string[];
	socials?: SocialLink[];
	reverse?: boolean;
	enterDelay?: string;
}

const {
	image,
	alt = '',
	name = '',
	role = '',
	bio = '',
	expertise = [],
	socials = [],
	reverse = false,
	enterDelay = '0s',
} = Astro.props;

const nameId = `team-member-${name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
const contentEnterFrom = reverse ? 'right' : 'left';
const imageEnterFrom = reverse ? 'left' : 'right';
const initials = name
	.split(/\s+/)
	.filter(Boolean)
	.slice(0, 2)
	.map((part) => part[0]?.toUpperCase() ?? '')
	.join('');
---

<li
	class={`team-member ${reverse ? 'reverse' : ''} team-member--animated`}
	role="region"
	aria-labelledby={nameId}
	data-team-reveal-group="true"
	style={`--team-enter-base-delay: ${enterDelay};`}
>
	<div
		class="text-block"
	>
		<p
			class="team-role team-reveal-target"
			data-enter-from={contentEnterFrom}
			style="--team-enter-delay: calc(var(--team-enter-base-delay) + 0.05s);"
		>
			{role}
		</p>
		<div class="team-header">
			<h3
				id={nameId}
				class="team-name text-gradient-brand team-reveal-target"
				data-enter-from={contentEnterFrom}
				style="--team-enter-delay: calc(var(--team-enter-base-delay) + 0.12s);"
			>
				{name}
			</h3>
		</div>
		<p
			class="team-bio team-reveal-target"
			data-enter-from={contentEnterFrom}
			style="--team-enter-delay: calc(var(--team-enter-base-delay) + 0.2s);"
		>
			{bio}
		</p>

		{expertise.length > 0 && (
			<ul class="team-expertise" aria-label={`${name} expertise`}>
				{expertise.map((item, index) => (
					<li
						class="team-expertise-pill team-reveal-target"
						data-enter-from={contentEnterFrom}
						style={`--team-enter-delay: calc(var(--team-enter-base-delay) + ${0.28 + index * 0.08}s);`}
					>
						<span>{item}</span>
					</li>
				))}
			</ul>
		)}

		{socials.length > 0 && (
			<ul
				class="team-social team-reveal-target"
				aria-label={`${name} social links`}
				data-enter-from={contentEnterFrom}
				style="--team-enter-delay: calc(var(--team-enter-base-delay) + 0.5s);"
			>
				{socials.map((s) => (
					<li>
						<a
							href={s.href}
							target="_blank"
							rel="noopener noreferrer"
							class="team-social-link"
							aria-label={s.label}
						>
							<Icon name={s.icon} width="20" height="20" aria-hidden="true" />
						</a>
					</li>
				))}
			</ul>
		)}
	</div>

	<div
		class="image-block team-reveal-target"
		data-enter-from={imageEnterFrom}
		style="--team-enter-delay: calc(var(--team-enter-base-delay) + 0.14s);"
	>
		{image ? (
			<Image
				src={image}
				alt={alt}
				width={480}
				height={480}
				loading="lazy"
				decoding="async"
				class="team-image"
			/>
		) : (
			<div class="team-photo-fallback" aria-hidden="true">
				<span>{initials}</span>
			</div>
		)}
	</div>
</li>

<style scoped>
.team-member {
	display: grid;
	gap: clamp(var(--space-lg), 3vw, var(--space-2xl));
	padding-block: var(--space-xl);
	text-align: center;
}

.text-block {
	max-width: 44rem;
	margin-inline: auto;
}

.team-member.reverse .text-block {
	text-align: left;
}

.team-member:not(.reverse) .text-block {
	text-align: right;
}

.team-header {
	display: flex;
	justify-content: center;
	margin-bottom: var(--space-sm);
}

.team-member.reverse .team-header {
	justify-content: flex-start;
}

.team-member:not(.reverse) .team-header {
	justify-content: flex-end;
}

.team-role {
	margin: 0 0 0.45rem;
	color: var(--color-tertiary);
	font-size: 0.82rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	text-transform: uppercase;
}

.team-name {
	margin: 0;
	font-size: clamp(2rem, 1.65rem + 1vw, 2.85rem);
	line-height: 0.96;
	letter-spacing: -0.06em;
	text-wrap: balance;
}

.team-bio {
	margin: 0 0 var(--space-md);
	color: var(--color-tertiary);
	font-size: var(--fontsize-editorial);
	line-height: var(--lineheight-editorial);
}

.team-member.reverse .team-bio {
	margin-inline: 0 auto;
}

.team-member:not(.reverse) .team-bio {
	margin-inline: auto 0;
}

.team-expertise {
	list-style: none;
	padding: 0;
	display: flex;
	flex-wrap: wrap;
	justify-content: center;
	gap: 0.85rem;
	max-width: 52rem;
	margin: 0;
}

.team-member.reverse .team-expertise {
	justify-content: flex-start;
	margin-inline: 0 auto;
}

.team-member:not(.reverse) .team-expertise {
	justify-content: flex-end;
	margin-inline: auto 0;
}

.team-expertise-pill {
	display: inline-flex;
	align-items: center;
	gap: 0.55rem;
	min-width: 0;
	padding: 0.95rem 1rem;
	border: 1px solid var(--color-quaternary);
	border-radius: 10px;
	background: color-mix(in srgb, var(--color-primary) 94%, var(--color-secondary) 6%);
	transition:
		opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
		transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
		border-color 0.25s ease,
		background-color 0.25s ease,
		box-shadow 0.25s ease;
	transition-delay: var(--team-enter-delay, 0s);
}

.team-expertise-pill span {
	min-width: 0;
	color: var(--color-secondary);
	font-size: clamp(0.96rem, 0.92rem + 0.16vw, 1.08rem);
	line-height: 1.2;
}

.team-social {
	list-style: none;
	display: flex;
	flex-wrap: nowrap;
	align-items: center;
	justify-content: center;
	gap: 0.85rem;
	margin: var(--space-md) 0 0;
	padding: 0;
}

.team-member.reverse .team-social {
	justify-content: flex-start;
}

.team-member:not(.reverse) .team-social {
	justify-content: flex-end;
}

.team-social-link {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	color: var(--color-tertiary);
	text-decoration: none;
	transition:
		color var(--transition-speed, 0.3s),
		transform var(--transition-speed, 0.3s);
}

.team-social-link:hover,
.team-social-link:focus-visible {
	color: var(--color-secondary);
	transform: translateY(-2px);
}

.team-social-link:focus-visible {
	outline: 2px solid color-mix(in srgb, var(--color-tertiary) 55%, transparent);
	outline-offset: 4px;
}

.image-block {
	min-width: 0;
}

.team-image,
.team-photo-fallback {
	display: block;
	width: 100%;
	height: auto;
	aspect-ratio: 1 / 1;
	border: 1px solid var(--color-quaternary);
	border-radius: 14px;
	object-fit: cover;
	background: color-mix(in srgb, var(--color-primary) 95%, var(--color-secondary) 5%);
}

.team-photo-fallback {
	display: grid;
	place-items: center;
	color: var(--color-secondary);
	font-size: clamp(2.5rem, 2rem + 2vw, 4rem);
	font-weight: 700;
	letter-spacing: -0.06em;
}

.team-member:hover .team-expertise-pill,
.team-member:focus-within .team-expertise-pill {
	border-color: color-mix(in srgb, var(--color-tertiary) 38%, var(--color-quaternary));
	background: color-mix(in srgb, var(--color-primary) 92%, var(--color-secondary) 8%);
	box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-tertiary) 12%, transparent);
}

.team-member--animated .team-reveal-target {
	will-change: transform, opacity;
	transition:
		opacity 0.95s ease-out,
		transform 0.95s ease-out;
	transition-delay: var(--team-enter-delay, 0s);
}

.team-member--animated .team-reveal-target[data-enter-state='pending'] {
	opacity: 0;
	transform: translate3d(0, 96px, 0);
}

.team-member--animated .team-reveal-target[data-enter-state='pending'][data-enter-from='left'] {
	transform: translate3d(calc(-100% - 96px), 0, 0);
}

.team-member--animated .team-reveal-target[data-enter-state='pending'][data-enter-from='right'] {
	transform: translate3d(calc(100% + 96px), 0, 0);
}

.team-member--animated .team-reveal-target[data-enter-state='visible'],
.team-member--animated .team-reveal-target.is-visible {
	opacity: 1;
	transform: translate3d(0, 0, 0);
}

@media (min-width: 48rem) {
	.team-member {
		grid-template-columns: minmax(0, 1.6fr) minmax(16rem, 22rem);
		align-items: center;
	}

	.team-member.reverse {
		direction: rtl;
	}

	.team-member.reverse .text-block,
	.team-member.reverse .image-block {
		direction: ltr;
	}

	.team-member .text-block {
		grid-column: 1;
	}

	.team-member .image-block {
		grid-column: 2;
	}
}

@media (max-width: 47.99rem) {
	.team-member {
		text-align: left;
	}

	.team-member .image-block {
		order: -1;
	}

	.team-member.reverse .text-block,
	.team-member:not(.reverse) .text-block {
		text-align: left;
	}

	.team-member.reverse .team-header,
	.team-member:not(.reverse) .team-header {
		justify-content: flex-start;
	}

	.team-member.reverse .team-bio,
	.team-member:not(.reverse) .team-bio,
	.team-member.reverse .team-expertise,
	.team-member:not(.reverse) .team-expertise,
	.team-member.reverse .team-social,
	.team-member:not(.reverse) .team-social,
	.team-member.reverse .text-block,
	.team-member:not(.reverse) .text-block {
		margin-inline: 0;
	}

	.team-member.reverse .team-social,
	.team-member:not(.reverse) .team-social,
	.team-member.reverse .team-expertise,
	.team-member:not(.reverse) .team-expertise {
		justify-content: flex-start;
	}
}

@media (prefers-reduced-motion: reduce) {
	.team-member--animated .team-reveal-target,
	.team-expertise-pill {
		transition: none;
	}
}
</style>

<script>
	if (typeof window !== 'undefined') {
		const groups = [...document.querySelectorAll('.team-member--animated[data-team-reveal-group]:not([data-team-reveal-bound])')];

		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
			groups.forEach((group) => {
				const targets = [...group.querySelectorAll('.team-reveal-target')];
				targets.forEach((target) => {
					target.classList.add('is-visible');
					target.setAttribute('data-enter-state', 'visible');
				});
				group.setAttribute('data-team-reveal-bound', 'true');
			});
		} else if (!window.__epdcTeamMemberObserver) {
			const observer = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (!entry.isIntersecting) continue;
						const group = entry.target;
						const targets = [...group.querySelectorAll('.team-reveal-target')];
						targets.forEach((target) => {
							target.classList.add('is-visible');
							target.setAttribute('data-enter-state', 'visible');
						});
						observer.unobserve(group);
					}
				},
				{
					threshold: 0.22,
					rootMargin: '0px 0px -10% 0px',
				}
			);

			const observeGroups = (targets) => {
				targets.forEach((group) => {
					const revealTargets = [...group.querySelectorAll('.team-reveal-target')];
					revealTargets.forEach((target) => {
						target.setAttribute('data-enter-state', 'pending');
					});
					group.setAttribute('data-team-reveal-bound', 'true');
					observer.observe(group);
				});
			};

			window.__epdcTeamMemberObserver = { observer, observeGroups };
			observeGroups(groups);
		} else {
			window.__epdcTeamMemberObserver.observeGroups(groups);
		}
	}
</script>
