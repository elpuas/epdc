---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import Button from '../../components/Button.astro';
import ServiceDetails from '../../components/ServiceDetails.astro';
import TrustedBy from '../../components/TrustedBy.astro';
import PricingCard from '../../components/PricingCard.astro';
import CaseStudySection from '../../components/CaseStudySection.astro';
import StructuredData from '../../components/StructuredData.astro';
import styles from '../../styles/Services.module.css';
const title = 'WordPress, E‑Commerce y Soporte White‑Label | ElPuas Digital Crafts';
const description = 'Desde desarrollos a medida hasta tiendas en línea y soporte a agencias — ofrecemos servicios web confiables, escalables y adaptados a tu presupuesto.';
import caseStudyImage from '../../../public/portfolio/cas-showcase.jpg';
import HomeProjectShowcase from '../../components/HomeProjectShowcase.astro';
import HomeProjectShowcaseVisual from '../../components/HomeProjectShowcaseVisual.astro';
const lang = 'es';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Servicios WordPress, E‑Commerce y White‑Label | ElPuas Digital Crafts',
  description: 'Desde desarrollo WordPress personalizado hasta WooCommerce y soporte para agencias — ofrecemos servicios web confiables que se adaptan a tus necesidades y planes de crecimiento.',
  url: 'https://elpuasdigitalcrafts.com/es/services',
  hasPart: [
    {
      '@type': 'Service',
      name: 'Desarrollo Web',
      description: 'Sitios personalizados o adaptados con tiempos de carga rápidos, diseño responsive, SEO y CMS integrado.'
    },
    {
      '@type': 'Service',
      name: 'Soluciones E‑Commerce',
      description: 'Tiendas WooCommerce optimizadas para conversión, integradas con logística y checkout eficiente.'
    },
    {
      '@type': 'Service',
      name: 'Mantenimiento y Soporte',
      description: 'Planes que incluyen actualizaciones de seguridad, backups, monitoreo y horas de desarrollo.'
    },
    {
      '@type': 'Service',
      name: 'Servicios White‑Label',
      description: 'Soporte de desarrollo confidencial y de alta calidad para agencias y estudios creativos.'
    }
  ]
}
---

<Layout {title} {description} {lang}>
  <section class={styles.hero} aria-labelledby="hero-title">
    <h1 id="hero-title" class="text-gradient-brand">Servicios Digitales Inteligentes y Escalables</h1>
    <p class={styles.accent}>Desde sitios web personalizados hasta soporte continuo, ayudamos a tu negocio a prosperar en línea.</p>
    <Button href="/es/contact" label="Conversemos" aria-label="Contáctanos para discutir tu proyecto" />
  </section>

  <section class={styles.servicesIntro} aria-labelledby="services-intro-title" role="region">
    <h2 id="services-intro-title">Lo Que Ofrecemos</h2>
    <p class={`${styles.accent} ${styles.subtitle}`}>Desde el lanzamiento inicial hasta el crecimiento a largo plazo, brindamos arte digital completo adaptado a las necesidades de tu negocio.</p>
    <div class={styles.servicesIntroGrid}>
        <ServiceDetails 
          icon="ph:code" 
          title="Desarrollo Web" 
          highlight={{
            icon: "ph:rocket-launch",
            title: "Rápido y Escalable",
            description: "Hecho para rendir, crecer y mantenerse fácil."
          }}
          features={[
            { label: "Mobile First", icon: "ph:device-mobile" },
            { label: "Alto Rendimiento", icon: "ph:lightning" },
            { label: "CMS Flexible", icon: "ph:puzzle-piece" },
            { label: "APIs Integradas", icon: "ph:plugs-connected" }
          ]}
          reverse={true}
          animateOnView={true}
        >
          <div slot="description">
            <span class={styles.accent}>Creamos sitios web</span> que se ajustan a tus objetivos, y a tu presupuesto. Ya sea que necesites un desarrollo completamente personalizado o una plantilla adaptada inteligentemente, creamos <span class={styles.accent}>sitios web de alto rendimiento</span> a medida para tu negocio. Desde sitios de inicio rápido hasta plataformas complejas, cada proyecto está optimizado para velocidad, escalabilidad y facilidad de gestión.
          </div>
        </ServiceDetails>

        <ServiceDetails 
          icon="ph:shopping-cart" 
          title="Soluciones de Comercio Electrónico" 
          highlight={{
            icon: "ph:trend-up",
            title: "Enfocado en Conversión",
            description: "Diseñado para convertir visitas en clientes."
          }}
          features={[
            { label: "Páginas que Venden", icon: "ph:storefront" },
            { label: "Checkout Ágil", icon: "ph:credit-card" },
            { label: "Inventario Sincronizado", icon: "ph:package" },
            { label: "Automatización Inteligente", icon: "ph:gear-six" }
          ]}
          reverse={false}
          animateOnView={true}
        >
          <div slot="description">
            Ya sea que estés lanzando tu <span class={styles.accent}>primera tienda</span> o escalando a miles de pedidos, construimos <span class={styles.accent}>soluciones WooCommerce</span> que son rápidas, confiables y optimizadas para conversión. Desde temas personalizados hasta flujos de pago avanzados e integraciones, te ayudamos a vender más — con menos fricción y soporte completo.
          </div>
        </ServiceDetails>

        <ServiceDetails 
          icon="ph:lifebuoy" 
          title="Mantenimiento y Soporte"  
          highlight={{
            icon: "ph:shield-check",
            title: "Siempre Protegido",
            description: "Monitoreo, actualizaciones y soporte continuo."
          }}
          features={[
            { label: "Actualizaciones Programadas", icon: "ph:arrows-clockwise" },
            { label: "Monitoreo Activo", icon: "ph:heartbeat" },
            { label: "Horas Dev Incluidas", icon: "ph:code" },
            { label: "Soporte Prioritario", icon: "ph:wrench" }
          ]}
          reverse={true}
          animateOnView={true}
        >
          <div slot="description">
            Nos encargamos de las <span class={styles.accent}>actualizaciones, seguridad y rendimiento</span> para que tú no tengas que hacerlo. Nuestros planes de mantenimiento y soporte incluyen actualizaciones del núcleo de WordPress y plugins, monitoreo de tiempo de actividad, <span class={styles.accent}>copias de seguridad regulares</span>, controles de seguridad y <span class={styles.accent}>ajuste de rendimiento</span>. ¿Necesitas ayuda rápida? Contáctanos directamente a través de Slack. Perfecto para negocios que desean tranquilidad y soporte proactivo — sin contratar un equipo interno de desarrollo.
          </div>
        </ServiceDetails>


        <ServiceDetails 
          icon="ph:mask-happy" 
          title="Servicios White-Label" 
          highlight={{
            icon: "ph:handshake",
            title: "Alianza Invisible",
            description: "Tu agencia brilla mientras construimos detrás."
          }}
          features={[
            { label: "Código para Cliente", icon: "ph:eye-slash" },
            { label: "Entrega Rápida", icon: "ph:timer" },
            { label: "Soporte Confiable", icon: "ph:lifebuoy" },
            { label: "Socio Confidencial", icon: "ph:handshake" }
          ]}
          reverse={false}
          animateOnView={true}
        >
          <div slot="description">
            Trabajamos perfectamente tras bambalinas para que tu <span class={styles.accent}>agencia pueda escalar</span> sin estrés. Desde <span class={styles.accent}>desarrollos pixel-perfect</span> hasta soporte continuo confiable, te hacemos quedar bien — tus clientes nunca necesitan saber que estuvimos allí.
          </div>
        </ServiceDetails>
    </div>
  </section>

  <section class={styles.pricing} aria-labelledby="pricing-title" role="region">
    <p class={styles.pricingEyebrow}>Planes por Suscripción</p>
    <h2 id="pricing-title" class="text-gradient-brand">Elige el plan que impulsa el crecimiento de tu negocio.</h2>
    <p class={styles.pricingDescription} id="pricing-subtitle">Planes mensuales diseñados para mantener tu sitio actualizado, seguro y en constante mejora.</p>
    <div class={styles.pricingGrid} role="list" aria-describedby="pricing-subtitle" data-pricing-reveal-group>
      <PricingCard
        title="Essential"
        description="Todo lo básico para mantener tu sitio funcionando correctamente."
        price="$150"
        period="/ mes"
        icon="ph:rocket-launch"
        href="/es/contact"
        enterDelay="0s"
        enterFrom="left"
        features={[
          'Actualizaciones y mantenimiento',
          'Backups regulares',
          'Seguridad y monitoreo',
          'Soporte por email'
        ]}
      />

      <PricingCard
        title="Growth"
        description="Para empresas que quieren evolucionar continuamente."
        price="$180"
        period="/ mes"
        icon="ph:trend-up"
        highlight
        badge="Más Popular"
        href="/es/contact"
        enterDelay="0.15s"
        enterFrom="bottom"
        features={[
          'Todo lo del plan Essential',
          'Hosting incluido',
          'Horas de desarrollo (2h/mes)',
          'Optimización de rendimiento',
          'Reportes mensuales'
        ]}
      />

      <PricingCard
        title="Premium"
        description="Soporte prioritario y capacidad de desarrollo continua."
        price="$250"
        period="/ mes"
        icon="ph:diamond"
        href="/es/contact"
        enterDelay="0.3s"
        enterFrom="right"
        features={[
          'Todo lo del plan Growth',
          'Horas de desarrollo (5h/mes)',
          'Soporte prioritario',
          'Consultoría técnica',
          'Implementaciones avanzadas'
        ]}
      />
    </div>
    <p class={styles.pricingTrust}>
      <span class={styles.pricingTrustIcon} aria-hidden="true">
        <Icon name="ph:shield-check" width="16" height="16" />
      </span>
      Todos los planes incluyen actualizaciones, monitoreo y copias de seguridad. <a href="/es/terms-and-conditions">Términos y Condiciones &rarr;</a>
    </p>
    <a class={styles.pricingSecondaryCta} href="/es/contact">
      ¿No estás seguro cuál elegir? Hablemos <span class={styles.pricingSecondaryCtaArrow} aria-hidden="true">&rarr;</span>
    </a>
  </section>

  <section class={styles.testimonial} aria-labelledby="testimonial-title" role="region">
    <HomeProjectShowcase
    title="Avalanche Advertising"
    description="Colaboración white-label continua para apoyar la ejecución técnica de proyectos web y digitales."
    linkLabel="Ver Proyecto"
    tags={[
      { icon: 'ph:handshake', label: 'White Label' },
      { icon: 'ph:buildings', label: 'Agencias' },
      { icon: 'ph:code', label: 'Desarrollo Web' },
      { icon: 'ph:headset', label: 'Soporte Continuo' },
    ]}
    tagsLabel="Características del proyecto"
    href="/es/crafted-with-love/cleveland-auto-show-wordpress-es/"
  >
    <HomeProjectShowcaseVisual
      slot="visual"
      src="/portfolio/CAS.webp"
      alt="Vista del proyecto Avalanche Advertising en la homepage"
    />
  </HomeProjectShowcase>
  </section>

  <section class={styles.ctaBlock} aria-labelledby="cta-title" role="region">
    <h2 id="cta-title" class="text-gradient-brand">¿Listo para lanzar o escalar tu próximo proyecto digital?</h2>
    <Button href="/es/contact" label="Comienza Hoy" aria-label="Contáctanos para comenzar con tu proyecto" />
  </section>
  <StructuredData data={structuredData} />
</Layout> 
