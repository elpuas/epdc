---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Button from '../../components/Button.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SupportTeaser from '../../components/SupportTeaser.astro';
import styles from '../../styles/Index.module.css';
import TrustedBy from '../../components/TrustedBy.astro';
import CaseStudySection from '../../components/CaseStudySection.astro';

// Import case study image
import caseStudyImage from '../../../public/phone-showcase.jpg';

const title = 'ElPuas Digital Crafts | Desarrollo Web con Amor y Precisión';
const description = 'Creamos sitios web rápidos, accesibles y escalables usando WordPress, Astro y flujos de trabajo potenciados por IA. Confiados por agencias y negocios en todo el mundo.';
const lang = 'es';
---

<Layout {title} {description} {lang}>
  <section class={styles.intro}>
    <p>Estudio pequeño, grandes resultados.</p>
    <Hero {lang} />
    <Button href="/es/services/" label="Ver Nuestros Servicios" />
  </section> 
  <section class={styles.services}>
    <div class={`${styles.withPattern} ${styles.dotsPattern}`}>
      <h2>En <span class={`${styles.brand} ${styles.accent}`}>ElPuas Digital Crafts</span>, no solo construimos sitios web, creamos plataformas digitales de alto rendimiento, impulsadas por IA y respaldadas por mantenimiento experto para crecer con tu negocio.</h2>
    </div>
  </section>
  <section class={styles.expertiseSection}>
    <h2 class="text-gradient-brand">Qué Hacemos</h2>
    <p class="subtitle">Entregamos más que código, construimos soluciones digitales que impulsan tu negocio.</p>
  
    <ul class={styles.servicesGrid}>
      <li>
        <ServiceCard 
        icon="ph:flask" 
        title="Desarrollo Web Personalizado" 
        description="Sitios web a medida construidos para velocidad, rendimiento y escalabilidad." 
        href="/es/services/" />
      </li>
      <li>
        <ServiceCard 
        icon="ph:shopping-cart" 
        title="Soluciones de Comercio Electrónico" 
        description="WooCommerce o headless — hacemos que vender sea fluido." 
        href="/es/services/" />
      </li>
      <li>
        <ServiceCard 
        icon="ph:lifebuoy" 
        title="Mantenimiento y Soporte" 
        description="Actualizaciones, optimizaciones y tranquilidad — gestionados para ti." 
        href="/es/services/" />
      </li>
      <li>
        <ServiceCard 
        icon="ph:mask-happy" 
        title="Servicios White-Label" 
        description="Construimos discretamente en segundo plano para que tu agencia brille." 
        href="/es/services/" />
      </li>
    </ul>
  </section>
  <CaseStudySection
    title="De Sitio Web a Motor de Crecimiento"
    accentText="FishCostaRica.com no solo obtuvo un sitio web — consiguió un socio."
    paragraph="Construimos un sitio personalizado diseñado para convertir, y continuamos optimizándolo a través de nuestro plan de mantenimiento mensual. ¿El resultado? Mayor visibilidad en búsquedas, mejor rendimiento y un aumento constante en las reservas — todo sin mover un dedo."
    quote="Desde el lanzamiento del nuevo sitio, hemos notado un impulso notable en las reservas y mejor visibilidad en búsquedas. ElPuas entendió nuestros objetivos y entregó resultados."
    author="Richard Krug, FishCostaRica.com"
    buttonLabel="Ver Caso de Estudio"
    buttonHref="/es/crafted-with-love/fishcostarica-tourism-es/" 
    imgSrc={caseStudyImage}
    imgAlt="FishCostaRica.com"
  />
  <SupportTeaser
    title="Planes por Suscripción"
    description="Planes mensuales para mantener tu sitio actualizado, seguro y en constante mejora."
    cards={[
      {
        icon: 'ph:shield-check',
        title: 'Actualizaciones y seguridad',
        description: 'Mantén WordPress, plugins y temas al día con copias de seguridad gestionadas.',
      },
      {
        icon: 'ph:code',
        title: 'Desarrollo continuo',
        description: 'Horas incluidas para mejoras, ajustes y nuevas funcionalidades.',
      },
      {
        icon: 'ph:gauge',
        title: 'Rendimiento estable',
        description: 'Revisiones proactivas para mantener el sitio rápido y confiable.',
      },
      {
        icon: 'ph:lightning',
        title: 'Soporte prioritario',
        description: 'Atención rápida para incidencias y solicitudes importantes.',
      },
    ]}
    ctaLabel="Explora Nuestros Planes"
    ctaHref="/es/services/#pricing-title"
  />
  <section class={styles.trustedBy}>
    <TrustedBy title="Con la confianza de marcas visionarias" />
  </section>
</Layout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0; 
  }
</style> 
