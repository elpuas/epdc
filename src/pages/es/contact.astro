---
import Layout from '../../layouts/Layout.astro';
import styles from '../../styles/Contact.module.css';
const title = 'Contactanos | Construyamos Juntos tu Próximo Sitio';
const description = 'Ya sea un sitio personalizado o soporte continuo, estamos para ayudarte. Contactá a ElPuas Digital Crafts — tu socio de confianza en la web.';
const lang = 'es';
---

<Layout {title} {description} {lang}>
  <section class={styles.contactIntro}>
    <h1>Construyamos Algo <span class="accent">Grandioso</span> Juntos</h1>
    <p>Completa el formulario — te responderemos dentro de 24 horas, sin robots de por medio.</p>
  </section>
  
  <form name="contact-es" method="POST" data-netlify="true" netlify-honeypot="bot-field" class={styles.contactForm}>
    <input type="hidden" name="form-name" value="contact" />
  
    <p class={styles.hidden}>
      <label for="bot-field-es">No completes esto si eres humano:</label>
      <input id="bot-field-es" name="bot-field" />
    </p>
  
    <p>
      <label for="name-es">¿Cuál es tu nombre? *</label>
      <input id="name-es" type="text" name="name" placeholder="Juan Pérez" required />
    </p>
  
    <p>
      <label for="email-es">Tu mejor correo electrónico *</label>
      <input id="email-es" type="email" name="email" placeholder="tu@ejemplo.com" required />
    </p>
  
    <p>
      <label for="service-es">¿Qué necesitas? *</label>
      <select id="service-es" name="service" required>
        <option value="">Elige un servicio...</option>
        <option value="Full Website">Necesito el paquete completo (Diseño + Desarrollo + Hosting)</option>
        <option value="E-Commerce">Una tienda online que realmente venda</option>
        <option value="Maintenance">Mantener mi sitio rápido y seguro</option>
        <option value="White-Label">Desarrollo white-label para mi agencia</option>
        <option value="Other">No estoy seguro aún, hablemos</option>
      </select>
    </p>
  
    <p>
      <label for="message-es">Cuéntanos tu historia *</label>
      <textarea id="message-es" name="message" rows="5" placeholder="Nos encantaría saber sobre tu proyecto, objetivos o incluso desafíos..." required></textarea>
    </p>
  
    <p>
      <input id="consent-es" type="checkbox" name="consent" required />
      <label for="consent-es">Estoy feliz de recibir comunicaciones de ElPuas Digital Crafts.</label>
    </p>
  
    <p>
      <button type="submit">Hablemos</button>
    </p>
  </form>
</Layout> 

<style>
  .accent {
    color: var(--color-tertiary);
    font-size: inherit;
  }
</style> 
