---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { Icon } from 'astro-icon/components';
import ServiceDetails from '../../components/ServiceDetails.astro';
import CaseStudySection from '../../components/CaseStudySection.astro';
import TeamMember from '../../components/TeamMember.astro';
import alfredoImage from '../../../public/team/alfredo-navas.jpeg';
import gianfrancoImage from '../../../public/team/gianfranco.png';
import styles from '../../styles/About.module.css';
const title = 'Conocé ElPuas Digital Crafts | Un Estudio Web Familiar';
const description = 'Descubrí quiénes somos, qué nos mueve y cómo creamos sitios web de alto rendimiento con un enfoque humano y personalizado. Un equipo pequeño con visión global.';
const lang = 'es';
// Import case study image
import caseStudyImage from '../../../public/monkey-phone.jpg';
const collaborationPoints = [
  {
    icon: 'ph:chat-centered-text',
    title: 'Comunicación Clara',
    highlight: {
      icon: 'ph:chat-circle-dots',
      title: 'Directa y ágil',
      description: 'Trabajás directamente con personas técnicas que explican prioridades, decisiones y próximos pasos con claridad.'
    },
    features: [
      { label: 'Contacto directo', icon: 'ph:phone-call' },
      { label: 'Respuestas rápidas', icon: 'ph:lightning' },
      { label: 'Prioridades claras', icon: 'ph:list-checks' },
      { label: 'Sin capas innecesarias', icon: 'ph:users-three' }
    ],
    description: 'Trabajar con EPDC se siente simple. Las preguntas se responden, las decisiones técnicas se entienden y la comunicación se mantiene directa desde el inicio hasta el soporte continuo.',
    reverse: true
  },
  {
    icon: 'ph:cpu',
    title: 'Experiencia Técnica Senior',
    highlight: {
      icon: 'ph:certificate',
      title: 'Experiencia que reduce fricción',
      description: 'Recibís criterio técnico sólido, sin complejidad innecesaria ni decisiones improvisadas.'
    },
    features: [
      { label: 'Visión de arquitectura', icon: 'ph:tree-structure' },
      { label: 'Enfoque en performance', icon: 'ph:gauge' },
      { label: 'Resolución de problemas', icon: 'ph:wrench' },
      { label: 'Ejecución confiable', icon: 'ph:check-circle' }
    ],
    description: 'Los clientes confían en EPDC porque podemos tomar buenas decisiones técnicas, resolver casos complejos con rapidez y mantener la calidad sin perder ritmo.',
    reverse: false
  },
  {
    icon: 'ph:rocket-launch',
    title: 'Tecnología Moderna, Decisiones Prácticas',
    highlight: {
      icon: 'ph:code',
      title: 'Stack moderno, decisiones sensatas',
      description: 'Elegimos herramientas que ayudan al proyecto, mejoran el mantenimiento y acompañan el crecimiento.'
    },
    features: [
      { label: 'Astro y React', icon: 'ph:atom' },
      { label: 'WordPress inteligente', icon: 'ph:puzzle-piece' },
      { label: 'Flujos con IA', icon: 'ph:sparkle' },
      { label: 'Implementaciones mantenibles', icon: 'ph:stack' }
    ],
    description: 'EPDC combina frameworks modernos, decisiones pragmáticas de CMS y flujos asistidos por IA para entregar sitios rápidos, flexibles y más fáciles de sostener en el tiempo.',
    reverse: true
  },
  {
    icon: 'ph:lifebuoy',
    title: 'Soporte a Largo Plazo',
    highlight: {
      icon: 'ph:shield-check',
      title: 'Soporte que sigue presente',
      description: 'No desaparecemos después de la entrega. Ayudamos a mantener, mejorar y extender el sitio con el tiempo.'
    },
    features: [
      { label: 'Mejoras continuas', icon: 'ph:arrows-clockwise' },
      { label: 'Correcciones prioritarias', icon: 'ph:first-aid-kit' },
      { label: 'Seguridad y actualizaciones', icon: 'ph:lock-key' },
      { label: 'Relación continua', icon: 'ph:handshake' }
    ],
    description: 'Muchos clientes siguen con EPDC porque el soporte forma parte de la relación. Acompañamos actualizaciones, mejoras y nuevas decisiones a medida que el negocio evoluciona.',
    reverse: false
  }
];
---

<Layout {title} {description} {lang}>
  <section class={styles.hero} aria-labelledby="page-title">
    <h1 id="page-title" class="page-title text-gradient-brand">Bienvenido a ElPuas Digital Crafts</h1>
    <p class={styles.lead}>
      Empoderamos a agencias y empresas con sitios web de alto rendimiento y pixel-perfect, construidos con cuidado y respaldados por soporte experto.
    </p>
  </section> 

  <section class={styles.about} aria-label="Sobre Nosotros">
    <p>Somos <span class={styles.accent}>ElPuas Digital Crafts</span>, un estudio web familiar que construye sitios web de alto rendimiento con amor, código y café.</p>

    <p>Creemos que los grandes sitios web van más allá del diseño. Deben ser ultrarrápidos, fáciles de gestionar y listos para crecer con tu negocio. Por eso utilizamos frameworks modernos como <span class={styles.accent}>Astro</span>, soluciones inteligentes de <span class={styles.accent}>WordPress</span> y flujos de trabajo <span class={styles.accent}>asistidos por IA</span> para entregar sitios web de alto rendimiento sin el alto costo de mantenimiento.</p>

    <p>Desde desarrollos personalizados de <span class={styles.accent}>WordPress</span> hasta plataformas optimizadas de <span class={styles.accent}>eCommerce</span>, creamos experiencias digitales que ayudan a crecer a pequeñas empresas y a escalar agencias. Ya sea que estés lanzando tu primer sitio o necesites un socio confiable de marca blanca, te respaldamos con comunicación clara, ejecución cuidadosa y soporte a largo plazo que realmente está presente.</p>

  </section>

  <section class={styles.values} aria-labelledby="values-title">
    <h2 id="values-title">Nuestros Valores</h2>
    <ul class={styles.valuesList} role="list" data-values-reveal-group>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:handshake" width="18" height="18" /></span>
        <span>Alianza Primero</span>
      </li>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0.08s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:rocket-launch" width="18" height="18" /></span>
        <span>Orientados a Resultados</span>
      </li>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0.16s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:brain" width="18" height="18" /></span>
        <span>Toque Humano</span>
      </li>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0.24s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:shield-check" width="18" height="18" /></span>
        <span>Seguridad y Confianza</span>
      </li>
    </ul>
  </section>

  <section class={styles.team} aria-labelledby="team-title">
    <h2 id="team-title">El Equipo</h2>
    <p class={styles.accent}>Conoce a las personas detrás de ElPuas Digital Crafts.</p>
    <ul class={styles.teamList} role="list">
      <TeamMember
        name="Catalina Valverde"
        role="CEO y Directora de Contenido"
        expertise={['Estrategia de contenido', 'Direccion editorial', 'Narrativa de marca']}
        bio="Catalina define la voz y la direccion editorial de cada proyecto para que cada sitio comunique con claridad, intención y coherencia de marca."
        enterDelay="0s"
      />
      <TeamMember
        image={alfredoImage}
        alt="Alfredo Navas - CTO y Desarrollador Principal"
        name="Alfredo Navas Fernandini"
        role="CTO"
        expertise={['Arquitectura WordPress', 'Desarrollo Astro', 'Liderazgo tecnico']}
        bio="Alfredo lidera la estrategia tecnica y la ejecucion, con mas de 15 años de experiencia senior en desarrollos a medida, rendimiento y plataformas web escalables."
        reverse={true}
        enterDelay="0.08s"
        socials={[
          { 
            href: 'https://www.linkedin.com/in/elpuasdev/', 
            icon: 'ph:linkedin-logo', 
            label: 'Perfil de LinkedIn de Alfredo' 
          },
          { 
            href: 'https://github.com/elpuasdev', 
            icon: 'ph:github-logo', 
            label: 'Perfil de GitHub de Alfredo' 
          },
          { 
            href: 'https://www.elpuas.com', 
            icon: 'ph:skull', 
            label: 'Sitio web personal de Alfredo' 
          }
        ]}
      />
      <TeamMember
        image={gianfrancoImage}
        alt="Gianfranco Navas - Lead Frontend Developer"
        name="Gianfranco Navas"
        role="Lead Frontend Developer"
        expertise={['Sistemas de diseño', 'Frontend', 'Interfaces accesibles']}
        bio="Gianfranco se enfoca en una ejecución frontend pulida, convirtiendo decisiones de diseño en interfaces responsivas, accesibles y consistentes."
        enterDelay="0.16s"
        socials={[
          { 
            href: 'https://www.linkedin.com/in/gianfranconavasfernandiniwebdeveloper/', 
            icon: 'ph:linkedin-logo', 
            label: 'Perfil de LinkedIn de Gianfranco' 
          },
          {
            href: 'https://github.com/gianfranco2605',
            icon: 'ph:github-logo',
            label: 'Perfil de GitHub de Gianfranco'
          },
          {
            href: 'https://x.com/gianfranco2605',
            icon: 'ph:x-logo',
            label: 'Perfil de X de Gianfranco'
          }
        ]}
      />
    </ul>
  </section>

  <section class={styles.philosophy} aria-label="Nuestra Filosofía">
    <h2>
      En ElPuas Digital Crafts, nuestra filosofía es simple:<span class={styles.accent}>"Creamos Artes Digitales para Humanos"</span> Cada proyecto está impregnado de cuidado, creatividad y artesanía, entregando no solo sitios web, sino experiencias digitales inolvidables.
    </h2>
  </section>

  <section class={styles.testimonial} aria-labelledby="case-study-title">
    <CaseStudySection
      title="E‑Commerce Construido para Escalar"
      quote="Construimos una tienda de comercio electrónico a medida para indumentaria médica y estudiantil, y continuamos optimizándola a través de nuestro plan de mantenimiento mensual. Utilizamos herramientas de IA para escribir mejores descripciones de productos y elegir las palabras clave adecuadas, ayudando al sitio a mantenerse por delante de los competidores en los resultados de búsqueda. ¿El resultado? Mayor visibilidad, experiencias de compra más fluidas y un crecimiento constante de las ventas, todo sin la molestia de gestionar la tecnología."
      author="MonkeyScrubs, Cliente de eCommerce + Plan de Soporte"
      buttonLabel="Caso de Estudio"
      buttonHref="/es/crafted-with-love/monkey-scrubs-ecommerce-es/" 
      imgSrc={caseStudyImage}
      imgAlt="Tienda eCommerce MonkeyScrubs mostrada en dispositivo móvil"
    />
  </section>

  <section class={styles.process} aria-labelledby="process-title">
    <h2 id="process-title" class="text-gradient-brand">Cómo Se Siente Trabajar con EPDC</h2>
    <p class={styles.accent}>Colaboración directa, ejecución senior, herramientas modernas y soporte que sigue siendo útil después del primer lanzamiento.</p>
    <div class={styles.processList}>
      {collaborationPoints.map((item) => (
        <ServiceDetails
          icon={item.icon}
          title={item.title}
          highlight={item.highlight}
          features={item.features}
          reverse={item.reverse}
          animateOnView={true}
        >
          <div slot="description">
            {item.description}
          </div>
        </ServiceDetails>
      ))}
    </div>
  </section>

  <section class={styles.cta} aria-label="Llamada a la Acción de Contacto">
    <Button href="/es/contact" label="Hablemos" />
  </section>
</Layout>
<script type="module" is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const valuePills = Array.from(document.querySelectorAll('[data-values-pill]'));

    if (valuePills.length > 0) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
        valuePills.forEach((pill) => {
          pill.classList.add('is-visible');
          pill.setAttribute('data-enter-state', 'visible');
        });
      } else {
        const valuesObserver = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-visible');
              entry.target.setAttribute('data-enter-state', 'visible');
              obs.unobserve(entry.target);
            });
          },
          {
            threshold: 0.2,
            rootMargin: '0px 0px -8% 0px',
          }
        );

        valuePills.forEach((pill) => {
          pill.setAttribute('data-enter-state', 'pending');
          valuesObserver.observe(pill);
        });
      }
    }

  });
</script>
