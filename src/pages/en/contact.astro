---
import Layout from '../../layouts/Layout.astro';
import styles from '../../styles/Contact.module.css';
const title = 'Contact Us | Let’s Build Your Next Website Together';
const description = 'Whether you need a custom site or ongoing support, we’re here to help. Contact ElPuas Digital Crafts — a trusted partner in building web experiences that work.';
const lang = 'en';
---

<Layout {title} {description} {lang}>
  <section class={styles.contactIntro}>
    <h1 class="text-gradient-brand">Let’s Build Something Great Together</h1>
    <p>Fill out the form — we’ll get back to you within 24 hours, no robots involved.</p>
  </section>
  
  <form name="contact-en" method="POST" data-netlify="true" netlify-honeypot="bot-field" class={styles.contactForm}>
    <input type="hidden" name="form-name" value="contact" />
  
    <p class={styles.hidden}>
      <label for="bot-field-en">Don’t fill this out if you're human:</label>
      <input id="bot-field-en" name="bot-field" />
    </p>
  
    <p>
      <label for="name-en">What's your name? *</label>
      <input id="name-en" type="text" name="name" placeholder="John Doe" required />
    </p>
  
    <p>
      <label for="email-en">Your best email *</label>
      <input id="email-en" type="email" name="email" placeholder="you@example.com" required />
    </p>
  
    <p>
      <label for="service-en">What do you need? *</label>
      <select id="service-en" name="service" required>
        <option value="">Pick a service...</option>
        <option value="Full Website">I need the full package (Design + Dev + Hosting)</option>
        <option value="E-Commerce">An online store that actually sells</option>
        <option value="Maintenance">Keep my site fast & secure</option>
        <option value="White-Label">White-label dev for my agency</option>
        <option value="Other">Not sure yet, let's chat</option>
      </select>
    </p>
  
    <p>
      <label for="message-en">Tell us your story *</label>
      <textarea id="message-en" name="message" rows="5" placeholder="We’d love to hear about your project, goals, or even challenges..." required></textarea>
    </p>
  
    <p>
      <input id="consent-en" type="checkbox" name="consent" required />
      <label for="consent-en">I’m happy to hear from ElPuas Digital Crafts.</label>
    </p>
  
    <p>
      <button type="submit">Let’s Talk</button>
    </p>
  </form>
</Layout> 
