---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Button from '../../components/Button.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SupportTeaser from '../../components/SupportTeaser.astro';
import HomeProjectShowcase from '../../components/HomeProjectShowcase.astro';
import HomeProjectShowcaseVisual from '../../components/HomeProjectShowcaseVisual.astro';
import styles from '../../styles/Index.module.css';
import TrustedBy from '../../components/TrustedBy.astro';

const title = 'ElPuas Digital Crafts | Web Development with Love and Precision';
const description = 'We build fast, affordable, and beautifully crafted websites for businesses and agencies — powered by WordPress, Astro, and AI-enhanced workflows. Based in Costa Rica, with clients worldwide.';
const lang = 'en';
---

<Layout {title} {description} {lang}>
    <section class={styles.intro}>
      <p>Small studio, big results.</p>
      <Hero {lang} />
      <Button href="/en/services/" label="View Our Services" />
    </section> 
    <section class={styles.services}>
      <div class={`${styles.withPattern} ${styles.dotsPattern}`}>
        <h2>At <span class={`${styles.brand} ${styles.accent}`}>ElPuas Digital Crafts</span>, we don't just build websites — we craft high-performance digital platforms, powered by AI and backed by expert maintenance to grow with your business.</h2>
      </div>
    </section>
    <section class={styles.expertiseSection}>
      <h2 class="text-gradient-brand">Our Expertise</h2>
      <p class="subtitle">We deliver more than code — we bring smart, reliable digital craftsmanship.</p>
    
      <ul class={styles.servicesGrid}>
        <li>
          <ServiceCard 
          icon="ph:flask" 
          title="Custom Web Development" 
          description="Tailor-made websites built for speed, performance, and scalability." 
          href="/en/services/" />
        </li>
        <li>
          <ServiceCard 
          icon="ph:shopping-cart" 
          title="E-Commerce Solutions" 
          description="WooCommerce or headless — we make selling seamless." 
          href="/en/services/" />
        </li>
        <li>
          <ServiceCard 
          icon="ph:lifebuoy" 
          title="Maintenance & Support" 
          description="Updates, optimizations, and peace of mind — handled for you." 
          href="/en/services/" />
        </li>
        <li>
          <ServiceCard 
          icon="ph:mask-happy" 
          title="White-Label Services" 
          description="We build quietly behind the scenes so your agency shines." 
          href="/en/services/" />
        </li>
      </ul>
    </section>
    <HomeProjectShowcase
      title="Nuara Pelletterie"
      description="Premium ecommerce experience developed for an Italian handcrafted leather goods brand."
      linkLabel="View Project"
      tags={[
        { icon: 'ph:shopping-cart', label: 'WooCommerce' },
        { icon: 'ph:pencil-line', label: 'Custom Design' },
        { icon: 'ph:globe-hemisphere-west', label: 'Multilingual' },
        { icon: 'ph:headset', label: 'Ongoing Support' },
      ]}
      tagsLabel="Project features"
      href="/en/crafted-with-love/nuara-pelletterie-ecommerce-en/"
    >
      <HomeProjectShowcaseVisual
        slot="visual"
        src="/epdc-nuara-card.webp"
        alt="Nuara Pelletterie project showcase image"
      />
    </HomeProjectShowcase>
    <SupportTeaser
      title="Ongoing Support That Grows With You"
      description="Monthly plans to keep your website updated, secure, and continuously improving."
      cards={[
        {
          icon: 'ph:shield-check',
          title: 'Updates and security',
          description: 'Keep WordPress, plugins, and themes up to date with managed backups.',
        },
        {
          icon: 'ph:code',
          title: 'Continuous development',
          description: 'Included development hours for improvements, adjustments, and new features.',
        },
        {
          icon: 'ph:gauge',
          title: 'Stable performance',
          description: 'Proactive reviews to keep the site fast and reliable.',
        },
        {
          icon: 'ph:lightning',
          title: 'Priority support',
          description: 'Faster attention for important issues and requests.',
        },
      ]}
      ctaLabel="Explore Our Plans"
      ctaHref="/en/services/#pricing-title"
    />
    <section class={styles.trustedBy}>
      <TrustedBy title="Trusted by forward-thinking brands" />
    </section>
</Layout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
