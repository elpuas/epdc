---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import Button from '../../components/Button.astro';
import ServiceDetails from '../../components/ServiceDetails.astro';
import TrustedBy from '../../components/TrustedBy.astro';
import PricingCard from '../../components/PricingCard.astro';
import CaseStudySection from '../../components/CaseStudySection.astro';
import StructuredData from '../../components/StructuredData.astro';
import styles from '../../styles/Services.module.css';
const title = 'WordPress, E‑Commerce & White‑Label Services | ElPuas Digital Crafts';
const description = 'From custom WordPress development to WooCommerce and agency support — we offer reliable web services that fit your needs, budget, and growth plans.';
import caseStudyImage from '../../../public/cas-showcase.jpg';
const lang = 'en';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'WordPress, E‑Commerce & White‑Label Services',
  description: 'From custom WordPress development to WooCommerce and agency support — we offer reliable web services that fit your needs, budget, and growth plans.',
  url: 'https://elpuasdigitalcrafts.com/en/services',
  hasPart: [
    {
      '@type': 'Service',
      name: 'Web Development',
      description: 'Custom-built or adapted websites with fast load times, SEO, responsive design, and CMS integrations.'
    },
    {
      '@type': 'Service',
      name: 'E-Commerce Solutions',
      description: 'WooCommerce sites optimized for conversion, logistics integration, and smooth checkout.'
    },
    {
      '@type': 'Service',
      name: 'Maintenance & Support',
      description: 'Plans including security updates, backups, monitoring, and expert dev time.'
    },
    {
      '@type': 'Service',
      name: 'White-Label Services',
      description: 'Confidential, pixel-perfect development support for creative agencies and studios.'
    }
  ]
}
---

<Layout {title} {description} {lang}>
  <section class={styles.hero} aria-labelledby="hero-title">
    <h1 id="hero-title" class="text-gradient-brand">Smart, Scalable Digital Services</h1>
    <p class={styles.accent}>From handcrafted websites to ongoing support — we help your business thrive online.</p>
    <Button href="/en/contact" label="Let's Talk" aria-label="Contact us to discuss your project" />
  </section>

  <section class={styles.servicesIntro} aria-labelledby="services-intro-title" role="region">
    <h2 id="services-intro-title">What We Offer</h2>
    <p class={`${styles.accent} ${styles.subtitle}`}>From initial launch to long-term growth, we provide complete digital craftsmanship tailored to your business needs.</p>
    <div class={styles.servicesIntroGrid}>
        <ServiceDetails 
          icon="ph:code" 
          title="Web Development" 
          features={["Responsive, mobile-first design", "Fast load times & SEO optimization", "Custom CMS integrations", "API and third-party service connectivity"]}
          reverse={true}
          animateOnView={true}
        >
          <div slot="description">
            We <span class={styles.accent}>craft websites</span> that fit your goals — and your budget. Whether you need a fully custom build or a smartly adapted template, we create <span class={styles.accent}>high-performance websites</span> tailored to your business. From fast-launch starter sites to complex platforms, every project is optimized for speed, scalability, and ease of management." 
          </div>
        </ServiceDetails>

        <ServiceDetails 
          icon="ph:shopping-cart" 
          title="E-Commerce Solutions" 
          features={["Conversion-focused product pages", "Streamlined checkout experiences", "Inventory & logistics integration", "Custom reports & automation"]}
          reverse={false}
          animateOnView={true}
        >
          <div slot="description">
            Whether you're launching your <span class={styles.accent}>first store</span> or scaling to thousands of orders, we build <span class={styles.accent}>WooCommerce solutions</span> that are fast, reliable, and conversion-optimized. From custom themes to advanced checkout flows and integrations, we help you sell more — with less friction and full support.
          </div>
        </ServiceDetails>

        <ServiceDetails 
          icon="ph:lifebuoy" 
          title="Maintenance & Support"  
          features={["Scheduled plugin and theme updates", "Performance & uptime monitoring", "Expert dev time included", "Priority bug fixes"]}
          reverse={true}
          animateOnView={true}
        >
          <div slot="description">
            We handle the <span class={styles.accent}>updates, security, and performance</span> so you don't have to. Our maintenance and support plans include WordPress core and plugin updates, uptime monitoring, <span class={styles.accent}>regular backups</span>, security checks, and <span class={styles.accent}>performance tuning</span>. Need help fast? Reach us directly via Slack. Perfect for businesses that want peace of mind and proactive support — without hiring an in-house dev team. 
          </div>
        </ServiceDetails>


        <ServiceDetails 
          icon="ph:mask-happy" 
          title="White-Label Services" 
          features={["Invisible client-ready code", "Fast delivery & scoped estimates", "Reliable dev support", "Confidential partnerships"]}
          reverse={false}
          animateOnView={true}
        >
          <div slot="description">
            We work seamlessly behind the scenes so your <span class={styles.accent}>agency can scale</span> without the stress. From <span class={styles.accent}>pixel-perfect builds</span> to reliable ongoing support, we make you look good — your clients never need to know we were there. 
          </div>
        </ServiceDetails>

    </div>
  </section>

  <section class={styles.pricing} aria-labelledby="pricing-title" role="region">
    <p class={styles.pricingEyebrow}>Subscription Plans</p>
    <h2 id="pricing-title" class="text-gradient-brand">Choose the plan that supports your next stage of growth.</h2>
    <p class={styles.pricingDescription} id="pricing-subtitle">Monthly plans designed to keep your site updated, secure, and improving over time.</p>
    <div class={styles.pricingGrid} role="list" aria-describedby="pricing-subtitle" data-pricing-reveal-group>
      <PricingCard
        title="Essential"
        description="Everything you need to keep your site running smoothly."
        price="$150"
        period="/ month"
        icon="ph:rocket-launch"
        href="/en/contact"
        ctaLabel="Get started"
        enterDelay="0s"
        enterFrom="left"
        features={[
          'Updates and maintenance',
          'Regular backups',
          'Security and monitoring',
          'Email support'
        ]}
      />

      <PricingCard
        title="Growth"
        description="For companies that want to keep evolving."
        price="$180"
        period="/ month"
        icon="ph:trend-up"
        highlight
        badge="Most Popular"
        href="/en/contact"
        ctaLabel="Get started"
        enterDelay="0.15s"
        enterFrom="bottom"
        features={[
          'Everything in Essential',
          'Hosting included',
          'Development hours (2h/month)',
          'Performance optimization',
          'Monthly reporting'
        ]}
      />

      <PricingCard
        title="Premium"
        description="Priority support with continuous development capacity."
        price="$250"
        period="/ month"
        icon="ph:diamond"
        href="/en/contact"
        ctaLabel="Get started"
        enterDelay="0.3s"
        enterFrom="right"
        features={[
          'Everything in Growth',
          'Development hours (5h/month)',
          'Priority support',
          'Technical consulting',
          'Advanced implementations'
        ]}
      />
    </div>
    <p class={styles.pricingTrust}>
      <span class={styles.pricingTrustIcon} aria-hidden="true">
        <Icon name="ph:shield-check" width="16" height="16" />
      </span>
      All plans include updates, monitoring, and backups. <a href="/en/terms-and-conditions">Terms and Conditions &rarr;</a>
    </p>
    <a class={styles.pricingSecondaryCta} href="/en/contact">
      Not sure which one fits best? Let’s talk <span class={styles.pricingSecondaryCtaArrow} aria-hidden="true">&rarr;</span>
    </a>
  </section>

  <section class={styles.testimonial} aria-labelledby="testimonial-title" role="region">
    <CaseStudySection
      title="Partnering Behind the Scenes"
      accentText=" We support agencies and studios through reliable, white-label execution."
      quote="Working with ElPuas has been a game-changer. They consistently deliver high-quality work on time, handle complex technical specs with ease, and elevate the quality of our agency's output. Our clients are happy — and that makes us look great."
      author=" Avalanche Advertising (White-label Partner)"
      buttonLabel="Crafted With Love"
      buttonHref="/en/crafted-with-love/" 
      imgSrc={caseStudyImage}
      imgAlt="Avalanche Advertising - White-label Partner"
    />
  </section>

  <TrustedBy title="Trusted by forward-thinking brands" />

  <section class={styles.ctaBlock} aria-labelledby="cta-title" role="region">
    <h2 id="cta-title">Ready to launch or scale your next digital project?</h2>
    <Button href="/en/contact" label="Get Started Today" aria-label="Contact us to get started with your project" />
  </section>
  <StructuredData data={structuredData} />
</Layout> 
