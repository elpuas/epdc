---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { Icon } from 'astro-icon/components';
import ServiceDetails from '../../components/ServiceDetails.astro';
import CaseStudySection from '../../components/CaseStudySection.astro';
import TeamMember from '../../components/TeamMember.astro';
import alfredoImage from '../../../public/team/alfredo-navas.jpeg';
import gianfrancoImage from '../../../public/team/gianfranco.png';
import styles from '../../styles/About.module.css';
const title = 'Meet ElPuas Digital Crafts | A Family-Led Web Studio';
const description = 'Discover who we are, what we stand for, and how we craft beautiful, high-performance websites. A small, skilled team with global reach and a personal touch.';
const lang = 'en';
// Import case study image
import caseStudyImage from '../../../public/portfolio/monkey-phone.jpg';
const collaborationPoints = [
  {
    icon: 'ph:chat-centered-text',
    title: 'Clear Communication',
    highlight: {
      icon: 'ph:chat-circle-dots',
      title: 'Direct and responsive',
      description: 'You work directly with experienced builders who keep priorities, tradeoffs, and next steps easy to follow.'
    },
    features: [
      { label: 'Direct contact', icon: 'ph:phone-call' },
      { label: 'Fast replies', icon: 'ph:lightning' },
      { label: 'Clear priorities', icon: 'ph:list-checks' },
      { label: 'No account maze', icon: 'ph:users-three' }
    ],
    description: 'Working with EPDC feels straightforward. Questions get answered, technical decisions get explained clearly, and communication stays direct from start to ongoing support.',
    reverse: true
  },
  {
    icon: 'ph:cpu',
    title: 'Senior Technical Expertise',
    highlight: {
      icon: 'ph:certificate',
      title: 'Experience that reduces friction',
      description: 'You get practical technical judgment, not junior-level guesswork or unnecessary complexity.'
    },
    features: [
      { label: 'Architecture insight', icon: 'ph:tree-structure' },
      { label: 'Performance focus', icon: 'ph:gauge' },
      { label: 'Problem solving', icon: 'ph:wrench' },
      { label: 'Reliable execution', icon: 'ph:check-circle' }
    ],
    description: 'Clients rely on us because we can make strong technical calls, solve edge cases quickly, and keep projects moving without losing quality or maintainability.',
    reverse: false
  },
  {
    icon: 'ph:rocket-launch',
    title: 'Modern Technology, Practical Decisions',
    highlight: {
      icon: 'ph:code',
      title: 'Modern stack, sensible choices',
      description: 'We choose tools that fit the project, improve maintainability, and support long-term growth.'
    },
    features: [
      { label: 'Astro and React', icon: 'ph:atom' },
      { label: 'Smart WordPress', icon: 'ph:puzzle-piece' },
      { label: 'AI-assisted workflows', icon: 'ph:sparkle' },
      { label: 'Maintainable builds', icon: 'ph:stack' }
    ],
    description: 'EPDC combines modern frameworks, pragmatic CMS decisions, and AI-assisted workflows to deliver websites that are fast, flexible, and easier to support over time.',
    reverse: true
  },
  {
    icon: 'ph:lifebuoy',
    title: 'Long-Term Support',
    highlight: {
      icon: 'ph:shield-check',
      title: 'Support that stays available',
      description: 'We do not disappear after handoff. We help clients maintain, improve, and extend their sites over time.'
    },
    features: [
      { label: 'Ongoing improvements', icon: 'ph:arrows-clockwise' },
      { label: 'Priority fixes', icon: 'ph:first-aid-kit' },
      { label: 'Security and updates', icon: 'ph:lock-key' },
      { label: 'Continuous partnership', icon: 'ph:handshake' }
    ],
    description: 'Many clients stay with EPDC because support is part of the relationship. We help with updates, improvements, and the next round of decisions as the business evolves.',
    reverse: false
  }
];
---

<Layout {title} {description} {lang}>
  <section class={styles.hero} aria-labelledby="page-title">
    <h1 id="page-title" class="page-title text-gradient-brand">Welcome to ElPuas Digital Crafts</h1>
    <p class={styles.lead}>
      We empower agencies and businesses with pixel-perfect, high-performance websites — built with care, backed by expert support.
    </p>
  </section> 

  <section class={styles.about} aria-label="About Us">
    <p>We're <span class={styles.accent}>ElPuas Digital Crafts</span> — a family-run web studio building high-performance websites with love, code, and coffee.</p>

    <p>We believe great websites go beyond design. They should be lightning-fast, easy to manage, and ready to grow with your business. That's why we use modern frameworks like <span class={styles.accent}>Astro</span>, smart <span class={styles.accent}>WordPress</span> solutions, and <span class={styles.accent}>AI-assisted</span> workflows to deliver handcrafted sites without the high-maintenance price tag.</p>

    <p>From custom <span class={styles.accent}>WordPress</span> builds to optimized <span class={styles.accent}>eCommerce</span> platforms, we create digital experiences that help small businesses grow and agencies scale. Whether you're launching your first site or need a reliable white-label partner, we've got your back — with clear communication, thoughtful execution, and long-term support that actually shows up.</p>

  </section>

  <section class={styles.values} aria-labelledby="values-title">
    <h2 id="values-title">What We Stand For</h2>
    <ul class={styles.valuesList} role="list" data-values-reveal-group>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:handshake" width="18" height="18" /></span>
        <span>Partnership First</span>
      </li>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0.08s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:rocket-launch" width="18" height="18" /></span>
        <span>Results-Driven</span>
      </li>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0.16s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:brain" width="18" height="18" /></span>
        <span>Human Touch</span>
      </li>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0.24s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:shield-check" width="18" height="18" /></span>
        <span>Security & Trust</span>
      </li>
    </ul>
  </section>

  <section class={styles.team} aria-labelledby="team-title">
    <h2 id="team-title">The Team</h2>
    <p class={styles.accent}>Meet the people behind ElPuas Digital Crafts.</p>
    <ul class={styles.teamList} role="list">
      <TeamMember
        name="Catalina Valverde"
        role="CEO & Head of Content"
        expertise={['Content strategy', 'Editorial direction', 'Brand storytelling']}
        bio="Catalina shapes the voice and editorial direction behind every project, helping each website communicate with clarity, purpose, and a strong sense of brand."
        enterDelay="0s"
      />
      <TeamMember
        image={alfredoImage}
        alt="Alfredo Navas - CTO and Lead Developer"
        name="Alfredo Navas Fernandini"
        role="CTO"
        expertise={['WordPress architecture', 'Astro development', 'Technical leadership']}
        bio="Alfredo leads technical strategy and delivery, bringing more than 15 years of senior development experience across custom builds, performance work, and scalable web platforms."
        reverse={true}
        enterDelay="0.08s"
        socials={[
          { 
            href: 'https://www.linkedin.com/in/elpuasdev/', 
            icon: 'ph:linkedin-logo', 
            label: 'Alfredo\'s LinkedIn profile' 
          },
          { 
            href: 'https://github.com/elpuasdev', 
            icon: 'ph:github-logo', 
            label: 'Alfredo\'s GitHub profile' 
          },
          { 
            href: 'https://www.elpuas.com', 
            icon: 'ph:skull', 
            label: 'Alfredo\'s personal website' 
          }
        ]}
      />
      <TeamMember
        image={gianfrancoImage}
        alt="Gianfranco Navas - Lead Frontend Developer"
        name="Gianfranco Navas"
        role="Lead Frontend Developer"
        expertise={['Design systems', 'Frontend craft', 'Accessible interfaces']}
        bio="Gianfranco focuses on polished frontend execution, translating design intent into responsive, accessible interfaces with strong attention to detail and consistency."
        enterDelay="0.16s"
        socials={[
          { 
            href: 'https://www.linkedin.com/in/gianfranconavasfernandiniwebdeveloper/', 
            icon: 'ph:linkedin-logo', 
            label: 'Gianfranco\'s LinkedIn profile' 
          },
          {
            href: 'https://github.com/gianfranco2605',
            icon: 'ph:github-logo',
            label: 'Gianfranco\'s GitHub profile'
          },
          {
            href: 'https://x.com/gianfranco2605',
            icon: 'ph:x-logo',
            label: 'Gianfranco\'s personal X profile'
          }
        ]}
      />
    </ul>
  </section>

  <section class={styles.philosophy} aria-label="Our Philosophy">
    <h2>
      At ElPuas Digital Crafts, our ethos is simple:<span class={styles.accent}>"We code Digital Crafts for Humans"</span> Each project is imbued with care, creativity, and craftsmanship, delivering not just websites, but unforgettable digital experiences.
    </h2>
  </section>

  <section class={styles.testimonial} aria-labelledby="case-study-title">
    <CaseStudySection
      title="E‑Commerce Built to Scale"
      quote="We built a tailored ecommerce store for medical and student apparel, and continue to optimize it through our monthly maintenance plan. We use AI tools to write better product descriptions and choose the right keywords, helping the site stay ahead of competitors in search results. The result? Higher visibility, smoother shopping experiences, and steady sales growth — all without the hassle of managing the tech."
      author="MonkeyScrubs, eCommerce + Support Plan Client"
      buttonLabel="Case Study"
      buttonHref="/en/crafted-with-love/monkey-scrubs-ecommerce-en/" 
      imgSrc={caseStudyImage}
      imgAlt="MonkeyScrubs eCommerce store displayed on mobile device"
    />
  </section>

  <section class={styles.process} aria-labelledby="process-title">
    <h2 id="process-title" class="text-gradient-brand">What It&apos;s Like to Work With EPDC</h2>
    <p class={styles.accent}>Direct collaboration, senior execution, modern tools, and support that stays useful after the first launch.</p>
    <div class={styles.processList}>
      {collaborationPoints.map((item) => (
        <ServiceDetails
          icon={item.icon}
          title={item.title}
          highlight={item.highlight}
          features={item.features}
          reverse={item.reverse}
          animateOnView={true}
        >
          <div slot="description">
            {item.description}
          </div>
        </ServiceDetails>
      ))}
    </div>
  </section>

  <section class={styles.cta} aria-label="Contact Call to Action">
    <Button href="/en/contact" label="Let's Talk" />
  </section>
</Layout>
<script type="module" is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const valuePills = Array.from(document.querySelectorAll('[data-values-pill]'));

    if (valuePills.length > 0) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
        valuePills.forEach((pill) => {
          pill.classList.add('is-visible');
          pill.setAttribute('data-enter-state', 'visible');
        });
      } else {
        const valuesObserver = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-visible');
              entry.target.setAttribute('data-enter-state', 'visible');
              obs.unobserve(entry.target);
            });
          },
          {
            threshold: 0.2,
            rootMargin: '0px 0px -8% 0px',
          }
        );

        valuePills.forEach((pill) => {
          pill.setAttribute('data-enter-state', 'pending');
          valuesObserver.observe(pill);
        });
      }
    }

  });
</script>
