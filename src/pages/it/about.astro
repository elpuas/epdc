---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { Icon } from 'astro-icon/components';
import ServiceDetails from '../../components/ServiceDetails.astro';
import TeamMember from '../../components/TeamMember.astro';
import alfredoImage from '../../../public/team/alfredo-navas.jpeg';
import gianfrancoImage from '../../../public/team/gianfranco.png';
import styles from '../../styles/About.module.css';
const title = 'Scopri ElPuas Digital Crafts | Uno Studio Web a Conduzione Familiare';
const description = 'Scopri chi siamo, cosa ci ispira e come creiamo esperienze digitali performanti. Un piccolo team con un grande cuore e visione globale.';
const lang = 'it';
import HomeProjectShowcase from '../../components/HomeProjectShowcase.astro';
import HomeProjectShowcaseVisual from '../../components/HomeProjectShowcaseVisual.astro';
const collaborationPoints = [
  {
    icon: 'ph:chat-centered-text',
    title: 'Comunicazione Chiara',
    highlight: {
      icon: 'ph:chat-circle-dots',
      title: 'Diretta e reattiva',
      description: 'Lavori direttamente con figure tecniche esperte che spiegano priorità, decisioni e prossimi passi con chiarezza.'
    },
    features: [
      { label: 'Contatto diretto', icon: 'ph:phone-call' },
      { label: 'Risposte rapide', icon: 'ph:lightning' },
      { label: 'Priorità chiare', icon: 'ph:list-checks' },
      { label: 'Niente passaggi inutili', icon: 'ph:users-three' }
    ],
    description: 'Lavorare con EPDC è lineare. Le domande trovano risposta, le decisioni tecniche vengono spiegate bene e la comunicazione resta diretta dall’inizio al supporto continuo.',
    reverse: true
  },
  {
    icon: 'ph:cpu',
    title: 'Esperienza Tecnica Senior',
    highlight: {
      icon: 'ph:certificate',
      title: 'Esperienza che riduce l’attrito',
      description: 'Ricevi giudizio tecnico solido, senza complessità superflua né decisioni improvvisate.'
    },
    features: [
      { label: 'Visione architetturale', icon: 'ph:tree-structure' },
      { label: 'Focus sulle performance', icon: 'ph:gauge' },
      { label: 'Problem solving', icon: 'ph:wrench' },
      { label: 'Esecuzione affidabile', icon: 'ph:check-circle' }
    ],
    description: 'I clienti si affidano a EPDC perché sappiamo prendere buone decisioni tecniche, risolvere casi complessi rapidamente e mantenere la qualità senza rallentare il lavoro.',
    reverse: false
  },
  {
    icon: 'ph:rocket-launch',
    title: 'Tecnologia Moderna, Scelte Pratiche',
    highlight: {
      icon: 'ph:code',
      title: 'Stack moderno, scelte sensate',
      description: 'Scegliamo strumenti che aiutano il progetto, migliorano la manutenzione e sostengono la crescita nel tempo.'
    },
    features: [
      { label: 'Astro e React', icon: 'ph:atom' },
      { label: 'WordPress intelligente', icon: 'ph:puzzle-piece' },
      { label: 'Workflow con IA', icon: 'ph:sparkle' },
      { label: 'Build manutenibili', icon: 'ph:stack' }
    ],
    description: 'EPDC unisce framework moderni, scelte CMS pragmatiche e workflow assistiti dall’IA per realizzare siti veloci, flessibili e più semplici da supportare nel tempo.',
    reverse: true
  },
  {
    icon: 'ph:lifebuoy',
    title: 'Supporto nel Lungo Periodo',
    highlight: {
      icon: 'ph:shield-check',
      title: 'Un supporto che resta presente',
      description: 'Non spariamo dopo la consegna. Aiutiamo a mantenere, migliorare ed estendere il sito nel tempo.'
    },
    features: [
      { label: 'Miglioramenti continui', icon: 'ph:arrows-clockwise' },
      { label: 'Fix prioritari', icon: 'ph:first-aid-kit' },
      { label: 'Sicurezza e aggiornamenti', icon: 'ph:lock-key' },
      { label: 'Partnership continua', icon: 'ph:handshake' }
    ],
    description: 'Molti clienti restano con EPDC perché il supporto fa parte del rapporto. Seguiamo aggiornamenti, miglioramenti e le decisioni successive mentre il business evolve.',
    reverse: false
  }
];
---

<Layout {title} {description} {lang}>
  <section class={styles.hero} aria-labelledby="page-title">
    <h1 id="page-title" class="page-title text-gradient-brand">Benvenuto a ElPuas Digital Crafts</h1>
    <p class={styles.lead}>
      Potenziamo agenzie e aziende con siti web ad alte prestazioni e pixel-perfect — costruiti con cura e supportati da esperti.
    </p>
  </section> 

  <section class={styles.about} aria-label="Chi Siamo">
    <p>Siamo <span class={styles.accent}>ElPuas Digital Crafts</span> — uno studio web a conduzione familiare che costruisce siti web ad alte prestazioni con amore, codice e caffè.</p>

    <p>Crediamo che i grandi siti web vadano oltre il design. Dovrebbero essere velocissimi, facili da gestire e pronti a crescere con la tua attività. Ecco perché utilizziamo framework moderni come <span class={styles.accent}>Astro</span>, soluzioni intelligenti <span class={styles.accent}>WordPress</span> e flussi di lavoro <span class={styles.accent}>assistiti dall'IA</span> per fornire siti artigianali senza l'elevato costo di manutenzione.</p>

    <p>Dalle personalizzazioni <span class={styles.accent}>WordPress</span> alle piattaforme <span class={styles.accent}>eCommerce</span> ottimizzate, creiamo esperienze digitali che aiutano le piccole imprese a crescere e le agenzie a scalare. Che tu stia lanciando il tuo primo sito o abbia bisogno di un partner affidabile white-label, ti supportiamo con comunicazione chiara, esecuzione attenta e supporto a lungo termine che è davvero presente.</p>

  </section>

  <section class={styles.values} aria-labelledby="values-title">
    <h2 id="values-title">I Nostri Valori</h2>
    <ul class={styles.valuesList} role="list" data-values-reveal-group>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:handshake" width="18" height="18" /></span>
        <span>Partnership Prima di Tutto</span>
      </li>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0.08s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:rocket-launch" width="18" height="18" /></span>
        <span>Orientati ai Risultati</span>
      </li>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0.16s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:brain" width="18" height="18" /></span>
        <span>Tocco Umano</span>
      </li>
      <li class={styles.valueItem} data-values-pill style="--service-enter-delay: 0.24s;">
        <span class={styles.valueIcon} aria-hidden="true"><Icon name="ph:shield-check" width="18" height="18" /></span>
        <span>Sicurezza e Fiducia</span>
      </li>
    </ul>
  </section>

  <section class={styles.team} aria-labelledby="team-title">
    <h2 id="team-title">Il Team</h2>
    <p class={styles.accent}>Incontra le persone dietro ElPuas Digital Crafts.</p>
    <ul class={styles.teamList} role="list">
      <TeamMember
        name="Catalina Valverde"
        role="CEO e Direttore dei Contenuti"
        expertise={['Strategia dei contenuti', 'Direzione editoriale', 'Storytelling di brand']}
        bio="Catalina definisce la voce e la direzione editoriale di ogni progetto, affinché ogni sito comunichi con chiarezza, intenzione e coerenza di brand."
        enterDelay="0s"
      />
      <TeamMember
        image={alfredoImage}
        alt="Alfredo Navas - CTO e Lead Developer"
        name="Alfredo Navas Fernandini"
        role="CTO"
        expertise={['Architettura WordPress', 'Sviluppo Astro', 'Leadership tecnica']}
        bio="Alfredo guida la strategia tecnica e la delivery, con oltre 15 anni di esperienza senior tra sviluppo custom, performance e piattaforme web scalabili."
        reverse={true}
        enterDelay="0.08s"
        socials={[
          { 
            href: 'https://www.linkedin.com/in/elpuasdev/', 
            icon: 'ph:linkedin-logo', 
            label: 'Profilo LinkedIn di Alfredo' 
          },
          { 
            href: 'https://github.com/elpuasdev', 
            icon: 'ph:github-logo', 
            label: 'Profilo GitHub di Alfredo' 
          },
          { 
            href: 'https://www.elpuas.com', 
            icon: 'ph:skull', 
            label: 'Sito web personale di Alfredo' 
          }
        ]}
      />
      <TeamMember
        image={gianfrancoImage}
        alt="Gianfranco Navas - Lead Frontend Developer"
        name="Gianfranco Navas"
        role="Lead Frontend Developer"
        expertise={['Design system', 'Frontend', 'Interfacce accessibili']}
        bio="Gianfranco si concentra su un frontend curato, trasformando le scelte di design in interfacce responsive, accessibili e coerenti."
        enterDelay="0.16s"
        socials={[
          { 
            href: 'https://www.linkedin.com/in/gianfranconavasfernandiniwebdeveloper/', 
            icon: 'ph:linkedin-logo', 
            label: 'Profilo LinkedIn di Gianfranco' 
          },
          {
            href: 'https://github.com/gianfranco2605',
            icon: 'ph:github-logo',
            label: 'Profilo GitHub di Gianfranco'
          },
          {
            href: 'https://x.com/gianfranco2605',
            icon: 'ph:x-logo',
            label: 'Profilo X di Gianfranco'
          }
        ]}
      />
    </ul>
  </section>

  <section class={styles.philosophy} aria-label="La Nostra Filosofia">
    <h2>
      In ElPuas Digital Crafts, la nostra filosofia è semplice:<span class={styles.accent}>"Codiamo Artigianato Digitale per Umani"</span> Ogni progetto è impregnato di cura, creatività e artigianalità, offrendo non solo siti web, ma esperienze digitali indimenticabili.
    </h2>
  </section>

  <section class={styles.testimonial} aria-labelledby="case-study-title">
    <HomeProjectShowcase
    title="Monkey Scrubs"
    description="Ecommerce progettato per crescere, ottimizzato continuamente tramite supporto tecnico, SEO e automazione."
    linkLabel="Vedi Progetto"
    tags={[
      { icon: 'ph:shopping-cart', label: 'WooCommerce' },
      { icon: 'ph:chart-line-up', label: 'Crescita Continua' },
      { icon: 'ph:magnifying-glass', label: 'SEO' },
      { icon: 'ph:headset', label: 'Supporto Mensile' },
    ]}
    tagsLabel="Caratteristiche del progetto"
    href="/it/crafted-with-love/monkey-scrubs-ecommerce-it/"
  >
    <HomeProjectShowcaseVisual
      slot="visual"
      src="/portfolio/monkeyscrubs-mobile.webp"
      alt="Vista del progetto Monkey Scrubs nella homepage"
    />
  </HomeProjectShowcase>
  </section>

  <section class={styles.process} aria-labelledby="process-title">
    <h2 id="process-title" class="text-gradient-brand">Com&apos;è Lavorare con EPDC</h2>
    <p class={styles.accent}>Collaborazione diretta, esecuzione senior, strumenti moderni e un supporto che resta utile anche dopo il primo lancio.</p>
    <div class={styles.processList}>
      {collaborationPoints.map((item) => (
        <ServiceDetails
          icon={item.icon}
          title={item.title}
          highlight={item.highlight}
          features={item.features}
          reverse={item.reverse}
          animateOnView={true}
        >
          <div slot="description">
            {item.description}
          </div>
        </ServiceDetails>
      ))}
    </div>
  </section>

  <section class={styles.cta} aria-label="Call to Action di Contatto">
    <Button href="/it/contact" label="Parliamone" />
  </section>
</Layout>
<script type="module" is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const valuePills = Array.from(document.querySelectorAll('[data-values-pill]'));

    if (valuePills.length > 0) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
        valuePills.forEach((pill) => {
          pill.classList.add('is-visible');
          pill.setAttribute('data-enter-state', 'visible');
        });
      } else {
        const valuesObserver = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-visible');
              entry.target.setAttribute('data-enter-state', 'visible');
              obs.unobserve(entry.target);
            });
          },
          {
            threshold: 0.2,
            rootMargin: '0px 0px -8% 0px',
          }
        );

        valuePills.forEach((pill) => {
          pill.setAttribute('data-enter-state', 'pending');
          valuesObserver.observe(pill);
        });
      }
    }

  });
</script>
