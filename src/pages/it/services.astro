---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import Button from '../../components/Button.astro';
import ServiceDetails from '../../components/ServiceDetails.astro';
import PricingCard from '../../components/PricingCard.astro';
import StructuredData from '../../components/StructuredData.astro';
import styles from '../../styles/Services.module.css';
const title = 'WordPress, E‑Commerce e Servizi White‑Label | ElPuas Digital Crafts';
const description = 'Dallo sviluppo su misura ai negozi online e al supporto per agenzie — offriamo servizi web affidabili, scalabili e adattati al tuo budget.';
import HomeProjectShowcase from '../../components/HomeProjectShowcase.astro';
import HomeProjectShowcaseVisual from '../../components/HomeProjectShowcaseVisual.astro';
const lang = 'it';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Servizi WordPress, E‑Commerce e White‑Label | ElPuas Digital Crafts',
  description: 'Dallo sviluppo WordPress su misura a WooCommerce e supporto per agenzie — offriamo servizi web affidabili pensati per le tue esigenze e la crescita del tuo business.',
  url: 'https://elpuasdigitalcrafts.com/it/services',
  hasPart: [
    {
      '@type': 'Service',
      name: 'Sviluppo Web',
      description: 'Siti web personalizzati o adattati con caricamento veloce, design responsive, SEO e integrazione CMS.'
    },
    {
      '@type': 'Service',
      name: 'Soluzioni E‑Commerce',
      description: 'Negozi WooCommerce ottimizzati per la conversione, integrati con logistica e checkout semplificato.'
    },
    {
      '@type': 'Service',
      name: 'Manutenzione e Supporto',
      description: 'Piani che includono aggiornamenti di sicurezza, backup, monitoraggio e ore di sviluppo incluse.'
    },
    {
      '@type': 'Service',
      name: 'Servizi White‑Label',
      description: 'Supporto tecnico riservato e di alta qualità per agenzie e studi creativi.'
    }
  ]
}
---

<Layout {title} {description} {lang}>
  <section class={styles.hero} aria-labelledby="hero-title">
    <h1 id="hero-title" class="text-gradient-brand">Servizi Digitali Intelligenti e Scalabili</h1>
    <p class={styles.accent}>Dai siti web artigianali al supporto continuo — aiutiamo la tua azienda a prosperare online.</p>
    <Button href="/it/contact" label="Parliamone" aria-label="Contattaci per discutere del tuo progetto" />
  </section>

  <section class={styles.servicesIntro} aria-labelledby="services-intro-title" role="region">
    <h2 id="services-intro-title">Cosa Offriamo</h2>
    <p class={`${styles.accent} ${styles.subtitle}`}>Dal lancio iniziale alla crescita a lungo termine, forniamo artigianato digitale completo su misura per le esigenze della tua azienda.</p>
    <div class={styles.servicesIntroGrid}>
        <ServiceDetails 
          icon="ph:code" 
          title="Sviluppo Web" 
          highlight={{
            icon: "ph:rocket-launch",
            title: "Rapido e Scalabile",
            description: "Pensato per performance, crescita e stabilità."
          }}
          features={[
            { label: "Mobile First", icon: "ph:device-mobile" },
            { label: "Alte Prestazioni", icon: "ph:lightning" },
            { label: "CMS Flessibile", icon: "ph:puzzle-piece" },
            { label: "API Integrate", icon: "ph:plugs-connected" }
          ]}
          reverse={true}
          animateOnView={true}
        >
          <div slot="description">
            <span class={styles.accent}>Creiamo siti web</span> che si adattano ai tuoi obiettivi — e al tuo budget. Che tu abbia bisogno di uno sviluppo completamente personalizzato o di un template adattato intelligentemente, creiamo <span class={styles.accent}>siti web ad alte prestazioni</span> su misura per la tua attività. Dai siti di avvio rapido alle piattaforme complesse, ogni progetto è ottimizzato per velocità, scalabilità e facilità di gestione.
          </div>
        </ServiceDetails>

        <ServiceDetails 
          icon="ph:shopping-cart" 
          title="Soluzioni E-Commerce" 
          highlight={{
            icon: "ph:trend-up",
            title: "Pensato per Convertire",
            description: "Progettato per trasformare visite in clienti."
          }}
          features={[
            { label: "Pagine che Convertono", icon: "ph:storefront" },
            { label: "Checkout Fluido", icon: "ph:credit-card" },
            { label: "Inventario Sincronizzato", icon: "ph:package" },
            { label: "Automazione Smart", icon: "ph:gear-six" }
          ]}
          reverse={false}
          animateOnView={true}
        >
          <div slot="description">
            Che tu stia lanciando il tuo <span class={styles.accent}>primo negozio</span> o scalando a migliaia di ordini, costruiamo <span class={styles.accent}>soluzioni WooCommerce</span> veloci, affidabili e ottimizzate per la conversione. Da temi personalizzati a flussi di checkout avanzati e integrazioni, ti aiutiamo a vendere di più — con meno attrito e supporto completo.
          </div>
        </ServiceDetails>

        <ServiceDetails 
          icon="ph:lifebuoy" 
          title="Manutenzione e Supporto"  
          highlight={{
            icon: "ph:shield-check",
            title: "Sempre Protetto",
            description: "Monitoraggio, aggiornamenti e supporto continuo."
          }}
          features={[
            { label: "Aggiornamenti Programmati", icon: "ph:arrows-clockwise" },
            { label: "Monitoraggio Attivo", icon: "ph:heartbeat" },
            { label: "Ore Dev Incluse", icon: "ph:code" },
            { label: "Fix Prioritari", icon: "ph:wrench" }
          ]}
          reverse={true}
          animateOnView={true}
        >
          <div slot="description">
            Ci occupiamo degli <span class={styles.accent}>aggiornamenti, della sicurezza e delle prestazioni</span> così che tu non debba farlo. I nostri piani di manutenzione e supporto includono aggiornamenti del core WordPress e dei plugin, monitoraggio dell'uptime, <span class={styles.accent}>backup regolari</span>, controlli di sicurezza e <span class={styles.accent}>ottimizzazione delle prestazioni</span>. Hai bisogno di aiuto veloce? Contattaci direttamente via Slack. Perfetto per le aziende che desiderano tranquillità e supporto proattivo — senza assumere un team di sviluppo interno.
          </div>
        </ServiceDetails>


        <ServiceDetails 
          icon="ph:mask-happy" 
          title="Servizi White-Label" 
          highlight={{
            icon: "ph:handshake",
            title: "Partnership Invisibile",
            description: "La tua agenzia brilla mentre costruiamo dietro le quinte."
          }}
          features={[
            { label: "Codice Pronto Cliente", icon: "ph:eye-slash" },
            { label: "Consegna Rapida", icon: "ph:timer" },
            { label: "Supporto Affidabile", icon: "ph:lifebuoy" },
            { label: "Partner Riservato", icon: "ph:handshake" }
          ]}
          reverse={false}
          animateOnView={true}
        >
          <div slot="description">
            Lavoriamo perfettamente dietro le quinte affinché la tua <span class={styles.accent}>agenzia possa scalare</span> senza stress. Da <span class={styles.accent}>costruzioni pixel-perfect</span> a supporto continuo affidabile, ti facciamo apparire al meglio — i tuoi clienti non hanno mai bisogno di sapere che c'eravamo noi.
          </div>
        </ServiceDetails>

    </div>
  </section>

  <section class={styles.pricing} aria-labelledby="pricing-title" role="region">
    <p class={styles.pricingEyebrow}>Piani in Abbonamento</p>
    <h2 id="pricing-title" class="text-gradient-brand">Scegli il piano che sostiene la crescita del tuo business.</h2>
    <p class={styles.pricingDescription} id="pricing-subtitle">Piani mensili pensati per mantenere il tuo sito aggiornato, sicuro e in costante miglioramento.</p>
    <div class={styles.pricingGrid} role="list" aria-describedby="pricing-subtitle" data-pricing-reveal-group>
      <PricingCard
        title="Essential"
        description="Tutto il necessario per mantenere il tuo sito operativo senza intoppi."
        price="$150"
        period="/ mese"
        icon="ph:rocket-launch"
        href="/it/contact"
        enterDelay="0s"
        enterFrom="left"
        features={[
          'Aggiornamenti e manutenzione',
          'Backup regolari',
          'Sicurezza e monitoraggio',
          'Supporto via email'
        ]}
      />

      <PricingCard
        title="Growth"
        description="Per aziende che vogliono evolvere con continuità."
        price="$180"
        period="/ mese"
        icon="ph:trend-up"
        highlight
        badge="Più Scelto"
        href="/it/contact"
        enterDelay="0.15s"
        enterFrom="bottom"
        features={[
          'Tutto ciò che include Essential',
          'Hosting incluso',
          'Ore di sviluppo (2h/mese)',
          'Ottimizzazione delle performance',
          'Report mensili'
        ]}
      />

      <PricingCard
        title="Premium"
        description="Supporto prioritario e capacità continua di sviluppo."
        price="$250"
        period="/ mese"
        icon="ph:diamond"
        href="/it/contact"
        enterDelay="0.3s"
        enterFrom="right"
        features={[
          'Tutto ciò che include Growth',
          'Ore di sviluppo (5h/mese)',
          'Supporto prioritario',
          'Consulenza tecnica',
          'Implementazioni avanzate'
        ]}
      />
    </div>
    <p class={styles.pricingTrust}>
      <span class={styles.pricingTrustIcon} aria-hidden="true">
        <Icon name="ph:shield-check" width="16" height="16" />
      </span>
      Tutti i piani includono aggiornamenti, monitoraggio e backup. <a href="/it/terms-and-conditions">Termini e Condizioni &rarr;</a>
    </p>
    <a class={styles.pricingSecondaryCta} href="/it/contact">
      Non sei sicuro di quale scegliere? Parliamone <span class={styles.pricingSecondaryCtaArrow} aria-hidden="true">&rarr;</span>
    </a>
  </section>

  <section class={styles.testimonial} aria-labelledby="testimonial-title" role="region">
    <HomeProjectShowcase
    title="Avalanche Advertising"
    description="Collaborazione white-label continua per supportare l'esecuzione tecnica di progetti web e digitali."
    linkLabel="Vedi Progetto"
    tags={[
      { icon: 'ph:handshake', label: 'White Label' },
      { icon: 'ph:buildings', label: 'Agenzie' },
      { icon: 'ph:code', label: 'Sviluppo Web' },
      { icon: 'ph:headset', label: 'Supporto Continuo' },
    ]}
    tagsLabel="Caratteristiche del progetto"
    href="/it/crafted-with-love/cleveland-auto-show-wordpress-it/"
  >
    <HomeProjectShowcaseVisual
      slot="visual"
      src="/portfolio/CAS.webp"
      alt="Vista del progetto Avalanche Advertising nella homepage"
    />
  </HomeProjectShowcase>
  </section>

  <section class={styles.ctaBlock} aria-labelledby="cta-title" role="region">
    <h2 id="cta-title" class="text-gradient-brand">Pronto a lanciare o scalare il tuo prossimo progetto digitale?</h2>
    <Button href="/it/contact" label="Inizia Oggi" aria-label="Contattaci per iniziare con il tuo progetto" />
  </section>
  <StructuredData data={structuredData} />
</Layout> 
