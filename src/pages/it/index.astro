---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Button from '../../components/Button.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SupportTeaser from '../../components/SupportTeaser.astro';
import styles from '../../styles/Index.module.css';
import TrustedBy from '../../components/TrustedBy.astro';
import CaseStudySection from '../../components/CaseStudySection.astro';

// Import case study image
import caseStudyImage from '../../../public/phone-showcase.jpg';

const title = 'ElPuas Digital Crafts | Sviluppo Web con Amore e Precisione';
const description = 'Realizziamo siti veloci, accessibili e scalabili con WordPress, Astro e flussi di lavoro potenziati dall’IA. Partner fidati di agenzie e aziende in tutto il mondo.';
const lang = 'it';
---

<Layout {title} {description} {lang}>
  <section class={styles.intro}>
    <p>Studio piccolo, grandi risultati.</p>
    <Hero {lang} />
    <Button href="/it/services" label="Scopri I Nostri Servizi" />
  </section> 
  <section class={styles.services}>
    <div class={`${styles.withPattern} ${styles.dotsPattern}`}>
      <h2>A <span class={`${styles.brand} ${styles.accent}`}>ElPuas Digital Crafts</span>, non ci limitiamo a costruire siti web — creiamo piattaforme digitali ad alte prestazioni, potenziate dall'IA e supportate da manutenzione esperta per crescere con la tua attività.</h2>
    </div>
  </section>
  <section class={styles.expertiseSection}>
    <h2 class="text-gradient-brand">La Nostra Competenza</h2>
    <p class="subtitle">Offriamo più che codice — portiamo artigianato digitale intelligente e affidabile.</p>
  
    <ul class={styles.servicesGrid}>
      <li>
        <ServiceCard 
        icon="ph:flask" 
        title="Sviluppo Web Personalizzato" 
        description="Siti web su misura costruiti per velocità, prestazioni e scalabilità." 
        href="/it/services/" />
      </li>
      <li>
        <ServiceCard 
        icon="ph:shopping-cart" 
        title="Soluzioni E-Commerce" 
        description="WooCommerce o headless — rendiamo la vendita senza problemi." 
        href="/it/services/" />
      </li>
      <li>
        <ServiceCard 
        icon="ph:lifebuoy" 
        title="Manutenzione e Supporto" 
        description="Aggiornamenti, ottimizzazioni e tranquillità — gestiti per te." 
        href="/it/services/#pricing-title" />
      </li>
      <li>
        <ServiceCard 
        icon="ph:mask-happy" 
        title="Servizi White-Label" 
        description="Costruiamo silenziosamente dietro le quinte così che la tua agenzia possa brillare." 
        href="/it/services/" />
      </li>
    </ul>
  </section>
  <CaseStudySection
    title="Da Sito Web a Motore di Crescita"
    accentText="FishCostaRica.com non ha ottenuto solo un sito web — ha trovato un partner."
    paragraph="Abbiamo costruito un sito personalizzato progettato per convertire, e continuiamo a ottimizzarlo attraverso il nostro piano di manutenzione mensile. Il risultato? Maggiore visibilità nelle ricerche, migliori prestazioni e un costante aumento delle prenotazioni — il tutto senza muovere un dito."
    quote="Dal lancio del nuovo sito, abbiamo visto un notevole incremento nelle prenotazioni e una migliore visibilità nelle ricerche. ElPuas ha compreso i nostri obiettivi e ha fornito risultati."
    author="Richard Krug, FishCostaRica.com"
    buttonLabel="Caso Studio"
    buttonHref="/it/crafted-with-love/fishcostarica-tourism-it/" 
    imgSrc={caseStudyImage}
    imgAlt="FishCostaRica.com"
  />
  <SupportTeaser
    title="Supporto Continuo Che Cresce Con Te"
    description="Piani mensili per mantenere il tuo sito aggiornato, sicuro e in costante miglioramento."
    cards={[
      {
        icon: 'ph:shield-check',
        title: 'Aggiornamenti e sicurezza',
        description: 'Mantieni WordPress, plugin e temi aggiornati con backup gestiti.',
      },
      {
        icon: 'ph:code',
        title: 'Sviluppo continuo',
        description: 'Ore incluse per miglioramenti, modifiche e nuove funzionalità.',
      },
      {
        icon: 'ph:gauge',
        title: 'Prestazioni stabili',
        description: 'Controlli proattivi per mantenere il sito veloce e affidabile.',
      },
      {
        icon: 'ph:lightning',
        title: 'Supporto prioritario',
        description: 'Risposta più rapida per problemi e richieste importanti.',
      },
    ]}
    ctaLabel="Esplora I Nostri Piani"
    ctaHref="/it/services/#pricing-title"
  />
  <section class={styles.trustedBy}>
    <TrustedBy title="Scelti da brand innovativi" />
  </section>
</Layout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style> 
